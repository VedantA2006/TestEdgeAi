function wc(s) { return s.trim()==='' ? 0 : s.trim().split(/\s+/).length; }
function updWC() {
var w = wc(stratText), mx = PLANS[curPlan].maxWords;
var pct = Math.min((w/mx)*100, 100);
var f = document.getElementById('wcFill'), l = document.getElementById('wcLbl');
f.style.width = pct + '%';
if (w > mx) {
f.style.background = '#DC2626'; l.textContent = w+' / '+mx+' (over limit)'; l.className = 'wc-lbl ov';
} else if (w > mx*.85) {
f.style.background = '#D97706'; l.textContent = w+' / '+mx+' words'; l.className = 'wc-lbl wn';
} else {
f.style.background = 'var(--navy)'; l.textContent = w+' / '+mx+' words'; l.className = 'wc-lbl';
}
var prev = document.getElementById('stratPrev');
if (stratText.trim()) {
prev.textContent = stratText.trim().substring(0,115) + (stratText.length>115 ? '…':'');
prev.classList.add('has');
} else {
prev.innerHTML = 'Tap to write your entry &amp; exit rules in full-screen…';
prev.classList.remove('has');
}
}
