var IMAP = {'Start Date':'fa-calendar-plus','End Date':'fa-calendar-check','Timeframe':'fa-clock','Total Return (%)':'fa-percent','CAGR (%)':'fa-arrow-trend-up','Max Drawdown (%)':'fa-arrow-trend-down','Win Rate (%)':'fa-bullseye','Profit Factor':'fa-scale-balanced','Sharpe Ratio':'fa-chart-line','Total Trades':'fa-repeat','Avg Trade':'fa-coins','Best Trade':'fa-trophy','Worst Trade':'fa-circle-exclamation'};
function renderM(raw) {
tlog('📊 Parsing results...','i');
var lines=raw.split('\n'); var sum=[],yr=[],mo=[],mode='';
lines.forEach(function(l){ var t=l.trim();
if(t==='BACKTEST SUMMARY:'){mode='s';return;} if(t==='YEARLY RETURNS:'){mode='y';return;} if(t==='MONTHLY RETURNS:'){mode='m';return;}
if(!t)return; if(mode==='s')sum.push(t); else if(mode==='y')yr.push(t); else if(mode==='m')mo.push(t);
});
var cont=document.getElementById('mCont'); cont.innerHTML='';
var list=document.createElement('div'); list.className='ml'; pdata.metrics={};
sum.forEach(function(line,i){
var ci=line.indexOf(':'); if(ci===-1)return;
var key=line.substring(0,ci).trim(), val=line.substring(ci+1).trim(); pdata.metrics[key]=val;
var row=document.createElement('div'); row.className='mr'; row.style.animationDelay=(i*.04)+'s';
var ico=IMAP[key]||'fa-circle-dot'; var vc='';
if(key.indexOf('Return')!==-1||key.indexOf('CAGR')!==-1){var n=parseFloat(val);if(!isNaN(n))vc=n>=0?' pos':' neg';}
if(key.indexOf('Drawdown')!==-1)vc=' neg';
row.innerHTML='<span class="mk"><i class="fa-solid '+ico+'"></i>'+escH(key)+'</span><span class="mv'+vc+'">'+escH(val)+'</span>';
list.appendChild(row);
});
cont.appendChild(list); updStats(pdata.metrics);
pdata.yearly=[]; yr.forEach(function(l){var p=l.split(':');if(p.length<2)return;pdata.yearly.push({year:p[0].trim(),value:parseFloat(p.slice(1).join(':').replace('%',''))});});
if(pdata.yearly.length){tlog('✅ '+pdata.yearly.length+' yearly records','s');renderYr();}
pdata.monthly=[]; mo.forEach(function(l){var p=l.split(':');if(p.length<2)return;var ms=p[0].trim(),num=parseFloat(p.slice(1).join(':').replace('%',''));var prs=parseMo(ms);if(prs)pdata.monthly.push({month:ms,year:prs.year,monthIndex:prs.monthIndex,value:num});});
if(pdata.monthly.length){tlog('✅ '+pdata.monthly.length+' monthly','s');renderHM();}
