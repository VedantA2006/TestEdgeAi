stratText = document.getElementById('wrTA').value;
closeWriter();
}
var pl = PLANS[curPlan];
var validA = assets.filter(function(a){return a.trim();});
var w = wc(stratText);
var prompt = buildPrompt();
if (!validA.length) { showToast('Enter at least one asset symbol before running.'); return; }
if (w > pl.maxWords) { showToast('Strategy text is '+w+' words — over the '+pl.maxWords+' word limit for '+pl.name+'.'); return; }
if (credits < pl.credits) { showToast('Need '+pl.credits+' credits for '+pl.name+'. You have '+credits+'.'); openBuy(); return; }
if (activeES) { activeES.close(); activeES = null; }

// ✅ NO SIDEBAR COLLAPSE - Keep sidebar visible
// collapseSidebar(); // REMOVED - sidebar stays visible

var btn = document.getElementById('runBtn');
btn.disabled = true;
btn.innerHTML = '<span class="bspin"></span>Running…';
document.getElementById('emptyW').style.display = 'none';
document.getElementById('resW').style.display = 'flex';
document.getElementById('stBdg').style.display = 'none';
document.getElementById('eqCard').style.display = 'none';
document.getElementById('retGrid').style.display = 'none';
document.getElementById('codeCard').style.display = 'none';
document.getElementById('srow').style.display = 'none';
document.getElementById('mCont').innerHTML = mkSkel();
tlog('━━━━━━━━━━━━━━━━━━━━━━━', 'b');
tlog('Backtest started — ' + pl.name, 'b');
tlog('Assets: ' + validA.join(', ') + '  |  TF: ' + curTf, 'i');
if (indicators.length) tlog('Indicators: ' + indicators.join(', '), 'i');
if (w > 0) tlog('Strategy words: ' + w + ' / ' + pl.maxWords, 'i');
tlog('Cost: ' + pl.credits + ' credit' + (pl.credits>1?'s':''), 'w');
setProg(5, 'Starting engine…');
var sid;
try {
var resp = await fetch('/api/strategy/start', {
method: 'POST',
headers: {'Content-Type':'application/json'},
body: JSON.stringify({prompt: prompt, plan: curPlan, timeframe: curTf, assets: validA, indicators: indicators})
});
var data = await resp.json();
if (!resp.ok) throw new Error(data.error || 'Server error');
sid = data.sessionId;
var nc = data.newCredits !== undefined ? data.newCredits : credits - pl.credits;
setCr(nc);
tlog('Session: ' + sid, 's');
tlog('Credits remaining: ' + nc, 'w');
} catch(err) {
tlog('✗ ' + err.message, 'e');
rstBtn(); hideProg();
return;
}
var es = new EventSource('/api/strategy/stream/' + sid);
activeES = es;
var typeMap = {info:'i', success:'s', error:'e', warn:'w'};
es.addEventListener('log',         function(e){var d=JSON.parse(e.data);tlog(d.msg,typeMap[d.type]||'i');});
es.addEventListener('progress',    function(e){var d=JSON.parse(e.data);setProg(d.value,d.label);});
es.addEventListener('code_status', function(e){var d=JSON.parse(e.data);setStat(d.state,d.message);});
es.addEventListener('code',        function(e){var d=JSON.parse(e.data);lastCode=d.code;document.getElementById('codeBox').textContent=d.code;document.getElementById('codeBox').classList.remove('err');document.getElementById('codeCard').style.display='block';});
es.addEventListener('output',      function(e){var d=JSON.parse(e.data);renderM(d.output);});
es.addEventListener('chart',       function(e){var img=document.getElementById('eqImg');img.src='/temp/equity.png?t='+Date.now()+'&s='+sid;img.onload=function(){document.getElementById('eqCard').style.display='block';tlog('✓ Equity curve ready','s');};img.onerror=function(){tlog('⚠ Chart image not found','w');};});
es.addEventListener('done',        function(e){
var d=JSON.parse(e.data);es.close();activeES=null;rstBtn();
if(d.success){setProg(100,'Complete — attempt '+d.attempt);tlog('✓ Backtest complete (attempt '+d.attempt+')','s');setStat('success','Completed');setTimeout(hideProg,3000);}
else{setStat('error','Failed');document.getElementById('codeBox').classList.add('err');if(!lastCode)document.getElementById('codeBox').textContent=d.error||'Execution failed';tlog('✗ '+(d.error||'Failed'),'e');hideProg();}
});
es.onerror = function(){tlog('⚠ Stream closed','w');es.close();activeES=null;rstBtn();};
}
