
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QuantAI Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
/* ══════════ TOKENS ══════════ */
:root{
--bg:#EEF2F7;
--glass-a:rgba(255,255,255,.55);
--glass-b:rgba(255,255,255,.75);
--glass-c:rgba(255,255,255,.88);
--glass-nav:rgba(255,255,255,.80);
--bdr:rgba(255,255,255,.85);
--bdr2:rgba(255,255,255,.95);
--blur:blur(24px) saturate(180%);
--sh-sm:0 2px 12px rgba(15,23,42,.07),inset 0 1px 0 rgba(255,255,255,.85);
--sh-md:0 6px 24px rgba(15,23,42,.09),inset 0 1px 0 rgba(255,255,255,.9);
--sh-lg:0 16px 48px rgba(15,23,42,.12),inset 0 1px 0 rgba(255,255,255,.95);
--navy:#0F2444;
--qa:#0284C7;--qb:rgba(2,132,199,.09);--qbd:rgba(2,132,199,.3);--qt:#025C8F;
--sa:#C2820A;--sb:rgba(194,130,10,.09);--sbd:rgba(194,130,10,.3);--st:#7A520A;
--ra:#7C3AED;--rb:rgba(124,58,237,.09);--rbd:rgba(124,58,237,.3);--rt:#5B21B6;
--ok:#059669;--okb:rgba(5,150,105,.1);--okbd:rgba(5,150,105,.3);
--er:#DC2626;--erb:rgba(220,38,38,.1);--erbd:rgba(220,38,38,.3);
--wn:#D97706;--wnb:rgba(217,119,6,.1);
--t900:#060F1F;--t800:#1A2942;--t700:#334155;--t600:#475569;
--t500:#64748B;--t400:#94A3B8;--t300:#CBD5E1;--t200:#E2E8F0;
--r-xs:6px;--r-sm:8px;--r-md:12px;--r-lg:16px;--r-xl:20px;--r-2xl:26px;
--fs:'DM Sans',system-ui,sans-serif;
--fm:'JetBrains Mono',monospace;
}
/* ══════════ RESET ══════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{font-family:var(--fs);background:var(--bg);color:var(--t700);-webkit-font-smoothing:antialiased;position:relative}
a{text-decoration:none;color:inherit}
button{font-family:var(--fs)}
input,textarea,select{font-family:var(--fs)}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(100,116,139,.25);border-radius:4px}
/* ══════════ BACKGROUND ══════════ */
#bgMesh{
position:fixed;inset:0;z-index:0;
pointer-events:none;
background:
radial-gradient(ellipse 70% 55% at 10% 35%, rgba(2,132,199,.13) 0%,transparent 60%),
radial-gradient(ellipse 55% 50% at 88% 18%, rgba(124,58,237,.09) 0%,transparent 55%),
radial-gradient(ellipse 45% 65% at 65% 92%, rgba(15,36,68,.07) 0%,transparent 55%),
radial-gradient(ellipse 35% 35% at 45% 55%, rgba(5,150,105,.05) 0%,transparent 45%),
linear-gradient(145deg,#EBF4FF 0%,#F5F7FA 45%,#EEF0F5 100%);
}
/* ══════════ ANIMATIONS ══════════ */
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
@keyframes slideInLeft{from{opacity:0;transform:translateX(-16px)}to{opacity:1;transform:none}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
@keyframes floatUp{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes popIn{0%{opacity:0;transform:scale(.85)}100%{opacity:1;transform:scale(1)}}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
/* ══════════ LAYOUT SHELL ══════════ */
#shell{
position:relative;z-index:1;
display:flex;flex-direction:column;
height:100vh;
isolation:isolate;
}
/* ══════════ NAVBAR ══════════ */
.nav{
flex-shrink:0;height:58px;
background:var(--glass-nav);
backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);
border-bottom:1px solid var(--bdr);
box-shadow:0 2px 10px rgba(15,23,42,.06),inset 0 -1px 0 rgba(255,255,255,.5);
display:flex;align-items:center;justify-content:space-between;
padding:0 22px;position:relative;z-index:100;
}
.brand{display:flex;align-items:center;gap:10px}
.blogo{
width:34px;height:34px;
background:linear-gradient(135deg,var(--navy),#0284C7);
border-radius:10px;display:flex;align-items:center;justify-content:center;
color:#fff;font-size:15px;
box-shadow:0 3px 10px rgba(2,132,199,.28),inset 0 1px 0 rgba(255,255,255,.2);
}
.bname{font-size:16px;font-weight:800;color:var(--navy);letter-spacing:-.5px}
.bname em{color:var(--qa);font-style:normal}
.nav-r{display:flex;align-items:center;gap:8px}
.eng-pill{display:flex;align-items:center;gap:6px;font-size:10px;font-weight:700;letter-spacing:.5px;color:var(--ok);background:var(--okb);border:1px solid var(--okbd);padding:5px 11px;border-radius:20px;font-family:var(--fm)}
.pdot{width:5px;height:5px;background:var(--ok);border-radius:50%;animation:pulse 2s infinite}
.cr-pill{display:flex;align-items:center;gap:7px;background:rgba(194,130,10,.08);border:1px solid rgba(194,130,10,.22);border-radius:24px;padding:4px 5px 4px 12px;cursor:pointer;transition:all .18s}
.cr-pill:hover{border-color:var(--sa);box-shadow:0 2px 10px rgba(194,130,10,.14)}
.cr-info{display:flex;flex-direction:column;line-height:1}
.cr-lbl{font-size:8px;font-weight:700;color:var(--st);text-transform:uppercase;letter-spacing:.8px;margin-bottom:1px}
.cr-val{font-family:var(--fm);font-size:14px;font-weight:700;color:var(--sa)}
.btn-buy{background:linear-gradient(135deg,var(--sa),#F59E0B);color:#fff;border:none;padding:5px 11px;border-radius:18px;font-size:11px;font-weight:700;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:4px;box-shadow:0 2px 8px rgba(194,130,10,.28)}
.btn-buy:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(194,130,10,.38)}
/* user menu */
.uw{position:relative}
.utrig{display:flex;align-items:center;gap:8px;background:var(--glass-a);border:1px solid var(--bdr);border-radius:24px;padding:4px 11px 4px 4px;cursor:pointer;transition:all .18s;backdrop-filter:blur(12px)}
.utrig:hover{background:var(--glass-b);box-shadow:var(--sh-sm)}
.uav{width:26px;height:26px;background:linear-gradient(135deg,var(--navy),var(--qa));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#fff;flex-shrink:0}
.unm{font-size:13px;font-weight:600;color:var(--t700);max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.uchev{font-size:8px;color:var(--t400);transition:transform .2s}
.uw.open .uchev{transform:rotate(180deg)}
.udd{position:absolute;top:calc(100% + 8px);right:0;min-width:210px;z-index:500;display:none;overflow:hidden;animation:fadeUp .15s ease both;background:var(--glass-c);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);border:1px solid var(--bdr2);border-radius:var(--r-lg);box-shadow:var(--sh-lg)}
.udd.open{display:block}
.ddhd{padding:13px 15px;background:rgba(255,255,255,.4);border-bottom:1px solid rgba(255,255,255,.55)}
.ddnm{font-size:14px;font-weight:700;color:var(--t900);margin-bottom:3px}
.ddcr{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--t500)}
.ddcr strong{color:var(--sa);font-family:var(--fm)}
.ddi{display:flex;align-items:center;gap:10px;padding:10px 15px;font-size:13px;color:var(--t700);cursor:pointer;transition:background .1s;border:none;background:none;width:100%;text-align:left}
.ddi:hover{background:rgba(255,255,255,.5);color:var(--t900)}
.ddi i{width:14px;color:var(--t400);font-size:12px}
.ddi.danger:hover{background:var(--erb);color:var(--er)}
.dddiv{height:1px;background:rgba(255,255,255,.55);margin:3px 0}
/* ══════════ APP ROW ══════════ */
.app-row{display:flex;flex:1;min-height:0;position:relative}
/* ══════════ SIDEBAR ══════════ */
.sidebar{
width:420px;flex-shrink:0;
display:flex;flex-direction:column;
background:var(--glass-a);
backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);
border-right:1px solid var(--bdr);
box-shadow:2px 0 16px rgba(15,23,42,.05),inset -1px 0 0 rgba(255,255,255,.45);
transition:width .4s cubic-bezier(.4,0,.2,1);
position:relative;z-index:10;
animation:slideInLeft .4s ease both;
}
.sidebar.mini{width:64px}
/* scrollable form area */
.sb-scroll{flex:1;min-height:0;overflow-y:auto;overflow-x:hidden}
.sb-form{padding:16px;display:flex;flex-direction:column;gap:14px}
.sidebar.mini .sb-form{display:none}
/* mini icon rail */
.sb-rail{display:none;flex-direction:column;align-items:center;gap:5px;padding:12px 0}
.sidebar.mini .sb-rail{display:flex}
.rail-ico{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:15px;border:1px solid rgba(255,255,255,.65);background:rgba(255,255,255,.45);color:var(--t500);cursor:pointer;transition:all .15s}
.rail-ico:hover{background:var(--glass-b);color:var(--t900);box-shadow:var(--sh-sm)}
.rail-ico.act{color:var(--qa);background:rgba(2,132,199,.1);border-color:rgba(2,132,199,.3)}
.rail-sep{width:28px;height:1px;background:rgba(100,116,139,.18);margin:2px 0}
/* run section */
.run-wrap{flex-shrink:0;padding:12px 16px;border-top:1px solid rgba(255,255,255,.5);background:rgba(255,255,255,.25);display:flex;flex-direction:column;gap:9px}
.sidebar.mini .run-full{display:none}
.sidebar.mini .run-wrap{padding:8px;align-items:center}
.run-mini-btn{display:none}
.sidebar.mini .run-mini-btn{display:flex;width:40px;height:40px;border-radius:11px;border:none;background:linear-gradient(135deg,var(--navy),#1D4ED8);color:#fff;align-items:center;justify-content:center;font-size:15px;cursor:pointer;box-shadow:0 3px 10px rgba(15,36,95,.28);transition:all .15s}
.sidebar.mini .run-mini-btn:hover{transform:scale(1.07)}
.cost-glass{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.45);border:1px solid rgba(255,255,255,.8);border-radius:var(--r-md);padding:9px 12px}
.cost-t{font-size:12px;font-weight:600;color:var(--t700)}
.cost-s{font-size:10px;color:var(--t400);margin-top:1px}
.cost-b{display:flex;align-items:center;gap:4px;font-family:var(--fm);font-size:16px;font-weight:700}
.btn-run{
width:100%;border:none;padding:12px 20px;border-radius:var(--r-md);
font-weight:800;font-size:14px;color:#fff;cursor:pointer;
background:linear-gradient(135deg,#0F2444 0%,#1D4ED8 60%,#0284C7 100%);
background-size:200% 100%;
display:flex;align-items:center;justify-content:center;gap:8px;
transition:all .25s;letter-spacing:.15px;
box-shadow:0 4px 16px rgba(15,36,95,.28),inset 0 1px 0 rgba(255,255,255,.15);
}
.btn-run:hover:not(:disabled){background-position:100% 0;transform:translateY(-2px);box-shadow:0 7px 24px rgba(15,36,95,.38)}
.btn-run:disabled{opacity:.5;cursor:not-allowed;transform:none}
.btn-run .bspin{width:14px;height:14px;border:2.5px solid rgba(255,255,255,.3);border-right-color:#fff;border-radius:50%;animation:spin .6s linear infinite;flex-shrink:0}
.ptrk{height:4px;background:rgba(100,116,139,.14);border-radius:3px;overflow:hidden;transition:opacity .3s}
.ptrk.hid{opacity:0;pointer-events:none}
.pfill{height:100%;background:linear-gradient(90deg,var(--qa),#818CF8);background-size:200% 100%;border-radius:3px;width:0%;transition:width .5s ease;animation:shimmer 2s linear infinite}
.p-note{font-size:9.5px;font-family:var(--fm);color:var(--t400);min-height:13px}
/* terminal */
.term-wrap{flex-shrink:0;height:210px;display:flex;flex-direction:column;border-top:1px solid rgba(255,255,255,.25)}
.sidebar.mini .term-wrap{height:calc(100% - 64px - 64px);min-height:100px}
.term-bar{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;padding:7px 12px;background:#13181F;border-bottom:1px solid rgba(255,255,255,.06)}
.tdots{display:flex;gap:4px}
.td{width:9px;height:9px;border-radius:50%}
.td:nth-child(1){background:#FF5F57}.td:nth-child(2){background:#FFBD2E}.td:nth-child(3){background:#28C840}
.t-title{font-family:var(--fm);font-size:9px;font-weight:600;color:#6E7681;text-transform:uppercase;letter-spacing:.9px;display:flex;align-items:center;gap:6px}
.t-title i{color:#58A6FF;font-size:10px}
.btn-clr{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);font-size:9px;font-weight:600;color:#6E7681;cursor:pointer;padding:3px 8px;border-radius:4px;font-family:var(--fm);transition:all .14s;display:flex;align-items:center;gap:4px}
.btn-clr:hover{background:rgba(255,255,255,.09);color:#C9D1D9}
.term-body{flex:1;min-height:0;overflow-y:auto;overflow-x:hidden;padding:8px 12px;font-family:var(--fm);font-size:11px;line-height:1.9;background:#0D1117}
.term-body::-webkit-scrollbar{width:3px}.term-body::-webkit-scrollbar-thumb{background:#21262D;border-radius:3px}
.tline{display:flex;gap:8px;align-items:flex-start;animation:fadeIn .18s ease both}
.tts{color:#30363D;font-size:9px;margin-top:.25em;flex-shrink:0;user-select:none}
.tmsg{word-break:break-all}
.t-i{color:#8B949E}.t-s{color:#3FB950;font-weight:600}.t-e{color:#F85149;font-weight:600}
.t-w{color:#E3B341;font-weight:500}.t-b{color:#E6EDF3;font-weight:700}.t-c{color:#79C0FF}
/* ══════════ FORM COMPONENTS ══════════ */
.sec-lbl{font-size:9.5px;font-weight:800;color:var(--t400);text-transform:uppercase;letter-spacing:1.1px;display:flex;align-items:center;gap:6px;margin-bottom:8px}
.sec-lbl i{font-size:11px;color:var(--t600)}
/* plan pills */
.plan-row{display:flex;gap:6px}
.pp{
flex:1;padding:10px 6px 8px;border-radius:var(--r-md);
background:rgba(255,255,255,.45);border:1.5px solid rgba(255,255,255,.7);
cursor:pointer;text-align:center;transition:all .18s;
display:flex;flex-direction:column;align-items:center;gap:3px;
backdrop-filter:blur(10px);
}
.pp:hover{background:var(--glass-b);box-shadow:var(--sh-sm);transform:translateY(-1px)}
.pp.sel.quick   {border-color:rgba(2,132,199,.45);background:rgba(2,132,199,.07);box-shadow:0 0 0 3px rgba(2,132,199,.09)}
.pp.sel.smart   {border-color:rgba(194,130,10,.45);background:rgba(194,130,10,.07);box-shadow:0 0 0 3px rgba(194,130,10,.09)}
.pp.sel.research{border-color:rgba(124,58,237,.45);background:rgba(124,58,237,.07);box-shadow:0 0 0 3px rgba(124,58,237,.09)}
.pp-ico{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px}
.quick .pp-ico   {background:var(--qb);color:var(--qa)}
.smart .pp-ico   {background:var(--sb);color:var(--sa)}
.research .pp-ico{background:var(--rb);color:var(--ra)}
.pp-name{font-size:10.5px;font-weight:700;color:var(--t700)}
.pp-cr{font-size:9px;font-weight:700;font-family:var(--fm);padding:2px 6px;border-radius:8px}
.quick .pp-cr   {background:var(--qb);color:var(--qt)}
.smart .pp-cr   {background:var(--sb);color:var(--st)}
.research .pp-cr{background:var(--rb);color:var(--rt)}
.plan-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.cmp-lnk{font-size:10px;font-weight:600;color:var(--qa);cursor:pointer;display:flex;align-items:center;gap:4px;transition:color .14s}
.cmp-lnk:hover{color:var(--qt)}
/* plan detail badge */
.plan-detail{
background:rgba(255,255,255,.4);border:1px solid rgba(255,255,255,.75);
border-radius:var(--r-md);padding:10px 12px;
display:flex;flex-wrap:wrap;gap:5px;
margin-top:6px;
}
.pd-chip{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:600;padding:3px 8px;border-radius:20px;background:rgba(255,255,255,.5);color:var(--t600);border:1px solid rgba(255,255,255,.7)}
.pd-chip i{font-size:10px}
.pd-chip.hl-q{background:var(--qb);color:var(--qt);border-color:var(--qbd)}
.pd-chip.hl-s{background:var(--sb);color:var(--st);border-color:var(--sbd)}
.pd-chip.hl-r{background:var(--rb);color:var(--rt);border-color:var(--rbd)}
/* field */
.field{display:flex;flex-direction:column;gap:5px}
.f-lbl{font-size:9.5px;font-weight:700;color:var(--t500);text-transform:uppercase;letter-spacing:1px;display:flex;align-items:center;gap:5px}
.f-lbl i{font-size:10px;color:var(--t400)}
.f-limit{margin-left:auto;font-family:var(--fm);font-size:8px;font-weight:600;padding:2px 6px;border-radius:6px;background:rgba(100,116,139,.1);color:var(--t400)}
.f-hint{font-size:10px;color:var(--t400);margin-top:2px}
/* glass input */
.g-inp{
width:100%;padding:9px 12px;
background:rgba(255,255,255,.58);
backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
border:1px solid rgba(255,255,255,.82);border-radius:var(--r-md);
font-size:13px;color:var(--t900);outline:none;
transition:all .17s;
box-shadow:0 1px 4px rgba(15,23,42,.04),inset 0 1px 0 rgba(255,255,255,.85);
}
.g-inp:focus{background:rgba(255,255,255,.82);border-color:rgba(2,132,199,.45);box-shadow:0 0 0 3px rgba(2,132,199,.09),0 2px 8px rgba(15,23,42,.05)}
.g-inp::placeholder{color:var(--t300)}
/* asset rows */
.asset-list{display:flex;flex-direction:column;gap:6px}
.asset-row{display:flex;align-items:center;gap:6px}
.asset-row .g-inp{flex:1}
.asset-idx{width:20px;font-size:10px;font-weight:700;font-family:var(--fm);color:var(--t400);flex-shrink:0;text-align:center}
.btn-rem{width:28px;height:28px;border-radius:7px;border:none;flex-shrink:0;background:rgba(220,38,38,.07);color:var(--er);display:flex;align-items:center;justify-content:center;font-size:11px;cursor:pointer;transition:all .13s}
.btn-rem:hover{background:rgba(220,38,38,.15)}
.btn-add{display:flex;align-items:center;gap:6px;background:rgba(255,255,255,.38);border:1.5px dashed rgba(100,116,139,.28);border-radius:var(--r-md);padding:8px 12px;font-size:12px;font-weight:600;color:var(--t500);cursor:pointer;transition:all .14s;width:100%}
.btn-add:hover{background:rgba(255,255,255,.6);border-color:var(--qa);color:var(--qa)}
/* timeframe chips */
.tf-wrap{display:flex;flex-wrap:wrap;gap:5px}
.tfc{
padding:5px 10px;border-radius:7px;font-size:11px;font-weight:700;font-family:var(--fm);
border:1px solid rgba(255,255,255,.75);background:rgba(255,255,255,.45);color:var(--t500);
cursor:pointer;transition:all .14s;backdrop-filter:blur(8px);
}
.tfc:hover{background:rgba(255,255,255,.78);color:var(--t700)}
.tfc.act.qt{background:rgba(2,132,199,.11);border-color:rgba(2,132,199,.38);color:var(--qt)}
.tfc.act.st{background:rgba(194,130,10,.11);border-color:rgba(194,130,10,.38);color:var(--st)}
.tfc.act.rt{background:rgba(124,58,237,.11);border-color:rgba(124,58,237,.38);color:var(--rt)}
/* history pill */
.hist-pill{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.45);border:1px solid rgba(255,255,255,.78);border-radius:var(--r-md);padding:8px 12px;font-size:12px;color:var(--t600);backdrop-filter:blur(8px)}
.hist-pill i{color:var(--t400);font-size:11px}
.hist-v{font-family:var(--fm);font-weight:600;color:var(--t800)}
.hist-n{font-size:10px;color:var(--t400);margin-left:auto}
/* indicator tag input */
.tag-box{
background:rgba(255,255,255,.58);
backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
border:1px solid rgba(255,255,255,.82);border-radius:var(--r-md);
padding:6px 8px;min-height:40px;max-height:88px;overflow-y:auto;
display:flex;flex-wrap:wrap;gap:5px;align-items:flex-start;
cursor:text;transition:all .17s;
box-shadow:0 1px 4px rgba(15,23,42,.04),inset 0 1px 0 rgba(255,255,255,.85);
}
.tag-box:focus-within{background:rgba(255,255,255,.82);border-color:rgba(2,132,199,.45);box-shadow:0 0 0 3px rgba(2,132,199,.09)}
.tag-chip{
display:inline-flex;align-items:center;gap:4px;
padding:3px 8px;border-radius:6px;font-size:11px;font-weight:600;font-family:var(--fm);
animation:popIn .18s ease both;flex-shrink:0;
}
.tag-chip.qt{background:var(--qb);color:var(--qt);border:1px solid rgba(2,132,199,.2)}
.tag-chip.st{background:var(--sb);color:var(--st);border:1px solid rgba(194,130,10,.2)}
.tag-chip.rt{background:var(--rb);color:var(--rt);border:1px solid rgba(124,58,237,.2)}
.tag-chip .t-x{background:none;border:none;cursor:pointer;color:inherit;padding:0;font-size:9px;opacity:.65;transition:opacity .1s;line-height:1;display:flex;align-items:center}
.tag-chip .t-x:hover{opacity:1}
.tag-real-input{border:none;background:none;outline:none;font-size:12px;color:var(--t800);min-width:90px;flex:1;font-family:var(--fm);padding:2px 0}
.tag-real-input::placeholder{color:var(--t300);font-size:11px}
/* strategy preview button */
.strat-btn{
background:rgba(255,255,255,.55);
border:1.5px solid rgba(255,255,255,.8);
border-radius:var(--r-md);padding:10px 12px;
cursor:pointer;transition:all .18s;text-align:left;width:100%;
display:flex;align-items:flex-start;gap:10px;min-height:58px;
box-shadow:0 1px 4px rgba(15,23,42,.04);
}
.strat-btn:hover{background:rgba(255,255,255,.78);border-color:rgba(2,132,199,.38);box-shadow:0 0 0 3px rgba(2,132,199,.07),var(--sh-sm)}
.strat-ico{color:var(--qa);font-size:13px;flex-shrink:0;margin-top:1px}
.strat-txt{font-size:12.5px;line-height:1.55;flex:1;color:var(--t400)}
.strat-txt.has{color:var(--t700)}
.strat-edit{font-size:10px;font-weight:700;color:var(--qa);display:flex;align-items:center;gap:3px;white-space:nowrap;flex-shrink:0}
/* word count */
.wc-row{display:flex;align-items:center;gap:8px;margin-top:3px}
.wc-tr{flex:1;height:3px;background:rgba(100,116,139,.14);border-radius:2px;overflow:hidden}
.wc-fill{height:100%;border-radius:2px;transition:width .28s,background .28s;width:0%;background:var(--navy)}
.wc-lbl{font-size:9px;font-weight:600;font-family:var(--fm);color:var(--t400);white-space:nowrap}
.wc-lbl.wn{color:var(--wn)}.wc-lbl.ov{color:var(--er)}
/* ══════════ STRATEGY OVERLAY ══════════ */
.write-overlay{
position:fixed;inset:0;z-index:900;
display:none;align-items:flex-end;
background:rgba(8,18,36,.28);
backdrop-filter:blur(5px);-webkit-backdrop-filter:blur(5px);
}
.write-overlay.open{display:flex;animation:fadeIn .2s ease both}
.write-panel{
width:100%;max-width:800px;height:84vh;
margin:0 auto;
display:flex;flex-direction:column;
background:rgba(255,255,255,.92);
backdrop-filter:blur(40px) saturate(220%);-webkit-backdrop-filter:blur(40px) saturate(220%);
border:1px solid rgba(255,255,255,.97);
border-radius:24px 24px 0 0;
box-shadow:0 -16px 50px rgba(15,23,42,.12),inset 0 1px 0 rgba(255,255,255,.98);
animation:slideUp .35s cubic-bezier(.32,.72,0,1) both;
}
.wr-handle{flex-shrink:0;display:flex;justify-content:center;padding:10px 0 6px}
.wr-handle-bar{width:32px;height:4px;background:rgba(100,116,139,.22);border-radius:2px}
.wr-head{flex-shrink:0;padding:0 22px 12px;display:flex;align-items:center;justify-content:space-between}
.wr-title{font-size:17px;font-weight:800;color:var(--t900);letter-spacing:-.3px;display:flex;align-items:center;gap:9px}
.wr-plan-badge{font-size:10px;font-weight:700;font-family:var(--fm);padding:3px 9px;border-radius:9px}
.wr-actions{display:flex;align-items:center;gap:8px}
.wr-meta{flex-shrink:0;padding:0 22px 12px;display:flex;flex-wrap:wrap;gap:6px}
.wr-meta-chip{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.82);border-radius:8px;padding:4px 10px;font-size:11px;font-weight:600;color:var(--t600);font-family:var(--fm)}
.wr-meta-chip i{font-size:10px;color:var(--t400)}
.wr-ta-wrap{flex:1;min-height:0;padding:0 22px;display:flex;flex-direction:column;gap:10px}
.wr-ta{
flex:1;min-height:0;width:100%;
padding:14px 16px;
background:rgba(255,255,255,.62);
border:1.5px solid rgba(255,255,255,.88);
border-radius:var(--r-lg);resize:none;outline:none;
font-size:14px;line-height:1.75;color:var(--t900);
transition:all .17s;
box-shadow:0 2px 10px rgba(15,23,42,.04),inset 0 1px 0 rgba(255,255,255,.92);
}
.wr-ta:focus{background:rgba(255,255,255,.85);border-color:rgba(2,132,199,.38);box-shadow:0 0 0 3px rgba(2,132,199,.08),0 4px 14px rgba(15,23,42,.06)}
.wr-ta::placeholder{color:var(--t300)}
.wr-foot{flex-shrink:0;padding:12px 22px 20px;display:flex;align-items:center;justify-content:space-between;border-top:1px solid rgba(255,255,255,.55);background:rgba(255,255,255,.25)}
.wr-wc-wrap{display:flex;align-items:center;gap:10px}
.wr-ring{position:relative;width:38px;height:38px;flex-shrink:0}
.wr-ring svg{transform:rotate(-90deg)}
.ring-track{fill:none;stroke:rgba(100,116,139,.13);stroke-width:3}
.ring-fill{fill:none;stroke-width:3;stroke-linecap:round;transition:stroke-dashoffset .38s ease,stroke .26s ease}
.wr-nums{}
.wr-big{font-size:15px;font-weight:800;font-family:var(--fm);color:var(--t900);line-height:1}
.wr-sub{font-size:8.5px;color:var(--t400);font-weight:600;text-transform:uppercase;letter-spacing:.4px}
.wr-hint{font-size:11px;color:var(--t400)}
.btn-apply{padding:11px 24px;border-radius:var(--r-md);border:none;background:linear-gradient(135deg,var(--navy),#1D4ED8);color:#fff;font-size:13px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(15,36,95,.25),inset 0 1px 0 rgba(255,255,255,.14);transition:all .2s;display:flex;align-items:center;gap:7px}
.btn-apply:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(15,36,95,.35)}
.btn-close-wr{width:30px;height:30px;border-radius:9px;border:none;background:rgba(100,116,139,.1);color:var(--t500);display:flex;align-items:center;justify-content:center;font-size:14px;cursor:pointer;transition:all .13s}
.btn-close-wr:hover{background:rgba(100,116,139,.2);color:var(--t700)}
/* ══════════ MAIN AREA ══════════ */
.main{flex:1;min-width:0;overflow-y:auto;padding:22px;display:flex;flex-direction:column;gap:16px;animation:fadeUp .4s ease .1s both}
/* ══════════ GLASS CARDS ══════════ */
.gc{background:var(--glass-b);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);border:1px solid var(--bdr);border-radius:var(--r-xl);box-shadow:var(--sh-sm);overflow:hidden;animation:fadeUp .35s ease both;transition:box-shadow .2s}
.gc:hover{box-shadow:var(--sh-md)}
.gc-hd{padding:13px 18px;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.3);border-bottom:1px solid rgba(255,255,255,.5)}
.gc-tit{display:flex;align-items:center;gap:9px;font-size:14px;font-weight:700;color:var(--t900)}
.gc-body{padding:18px}
.gc-acts{display:flex;gap:6px}
/* stats */
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.stat-c{background:var(--glass-b);backdrop-filter:var(--blur);border:1px solid var(--bdr);border-radius:var(--r-lg);padding:16px;text-align:center;box-shadow:var(--sh-sm);transition:all .18s}
.stat-c:hover{transform:translateY(-2px);box-shadow:var(--sh-md)}
.sv{font-size:26px;font-weight:800;color:var(--navy);margin-bottom:3px;letter-spacing:-1px}
.sv.pos{color:var(--ok)}.sv.neg{color:var(--er)}
.slb{font-size:9.5px;color:var(--t400);text-transform:uppercase;letter-spacing:.8px;font-weight:700}
.r2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
/* metrics */
.ml{display:flex;flex-direction:column}
.mr{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid rgba(100,116,139,.07);animation:fadeIn .28s ease both}
.mr:last-child{border-bottom:none}
.mk{font-size:12.5px;color:var(--t500);display:flex;align-items:center;gap:7px}
.mk i{font-size:11px;color:var(--t300);width:13px;text-align:center}
.mv{font-family:var(--fm);font-size:12.5px;font-weight:600;color:var(--t900)}
.mv.pos{color:var(--ok)}.mv.neg{color:var(--er)}
/* status badge */
.sbdg{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:700;padding:4px 9px;border-radius:20px;text-transform:uppercase;letter-spacing:.5px;font-family:var(--fm)}
.sbdg-r{background:rgba(59,130,246,.1);color:#2563EB;border:1px solid rgba(59,130,246,.25)}
.sbdg-s{background:var(--okb);color:var(--ok);border:1px solid var(--okbd)}
.sbdg-e{background:var(--erb);color:var(--er);border:1px solid var(--erbd)}
/* btns */
.btn{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.82);color:var(--t500);padding:6px 12px;border-radius:var(--r-sm);font-size:12px;font-weight:600;cursor:pointer;transition:all .14s;backdrop-filter:blur(8px)}
.btn:hover{background:var(--glass-b);color:var(--t700);transform:translateY(-1px);box-shadow:var(--sh-sm)}
.btn-prim{background:linear-gradient(135deg,var(--navy),#1D4ED8);border-color:transparent;color:#fff;box-shadow:0 3px 10px rgba(15,36,95,.22)}
.btn-prim:hover{color:#fff;box-shadow:0 5px 14px rgba(15,36,95,.32)}
/* code */
.cpre{background:#0D1117;padding:16px;font-family:var(--fm);font-size:11.5px;line-height:1.75;color:#8B949E;white-space:pre;overflow:auto;min-height:100px;max-height:460px}
.cpre.err{background:var(--erb);color:var(--er)}
/* chart / heatmap */
.cwrap{position:relative;height:255px}
.cimg{width:100%;height:auto;border-radius:var(--r-sm);display:block;border:1px solid rgba(255,255,255,.55);animation:fadeIn .38s ease both}
.hmg{display:grid;grid-template-columns:40px repeat(12,1fr);gap:3px;padding:12px}
.hmc0{}
.hmmh{font-size:8px;font-weight:700;color:var(--t400);text-align:center;padding:3px 0;font-family:var(--fm)}
.hmyr{font-family:var(--fm);font-size:9px;font-weight:600;color:var(--t500);display:flex;align-items:center;justify-content:flex-end;padding-right:4px}
.hmcell{aspect-ratio:1;border-radius:3px;display:flex;align-items:center;justify-content:center;font-weight:700;font-family:var(--fm);font-size:8.5px;cursor:pointer;transition:all .11s}
.hmcell:hover{transform:scale(1.2);z-index:2;box-shadow:0 2px 8px rgba(0,0,0,.14)}
.hmcell.pos{color:#fff}.hmcell.neg{color:#fff}.hmcell.nil{background:rgba(100,116,139,.1);color:var(--t300)}
.hmleg{display:flex;align-items:center;gap:7px;padding:7px 12px;font-size:9px;color:var(--t400);border-top:1px solid rgba(255,255,255,.45);font-family:var(--fm)}
.hmgr{display:flex;gap:2px;flex:1;max-width:150px}.hmgr span{flex:1;height:7px;border-radius:2px}
/* dl dropdown */
.dlw{position:relative;display:inline-block}
.dlm{position:absolute;top:calc(100% + 5px);right:0;background:var(--glass-c);backdrop-filter:var(--blur);border:1px solid var(--bdr2);border-radius:var(--r-md);box-shadow:var(--sh-lg);min-width:158px;z-index:50;display:none;animation:fadeUp .13s ease both;overflow:hidden}
.dlm.open{display:block}
.dlit{display:flex;align-items:center;gap:9px;padding:10px 13px;font-size:12px;color:var(--t700);cursor:pointer;transition:background .1s;border:none;background:none;width:100%;text-align:left}
.dlit:hover{background:rgba(255,255,255,.5)}
.dlit i{width:13px;color:var(--t400)}
/* skeleton */
.skel{background:linear-gradient(90deg,rgba(100,116,139,.09) 25%,rgba(100,116,139,.17) 50%,rgba(100,116,139,.09) 75%);background-size:200% 100%;border-radius:5px;animation:shimmer 1.5s ease-in-out infinite}
.spini{width:12px;height:12px;border:2px solid rgba(59,130,246,.2);border-right-color:#3B82F6;border-radius:50%;animation:spin .6s linear infinite;display:inline-block;flex-shrink:0}
/* empty */
.empty{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:360px;gap:14px;text-align:center;padding:40px 28px}
.eico{width:68px;height:68px;background:var(--glass-b);backdrop-filter:var(--blur);border:1px solid var(--bdr);border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:26px;color:var(--t300);box-shadow:var(--sh-sm);animation:floatUp 3s ease-in-out infinite}
.etit{font-size:20px;font-weight:800;color:var(--t700);letter-spacing:-.4px}
.edsc{font-size:13px;line-height:1.65;max-width:290px;color:var(--t400)}
.ehints{display:flex;flex-direction:column;gap:7px;margin-top:6px;width:100%;max-width:300px}
.ehint{display:flex;align-items:center;gap:9px;font-size:12px;color:var(--t600);background:var(--glass-a);border:1px solid var(--bdr);border-radius:10px;padding:8px 13px;backdrop-filter:blur(8px)}
.ehint i{font-size:13px;flex-shrink:0;width:16px;text-align:center}
/* ══════════ MODALS ══════════ */
.mbg{position:fixed;inset:0;background:rgba(8,18,36,.32);backdrop-filter:blur(7px);-webkit-backdrop-filter:blur(7px);z-index:800;display:none;align-items:center;justify-content:center;padding:18px}
.mbg.open{display:flex;animation:fadeIn .18s ease both}
.mbox{background:rgba(255,255,255,.91);backdrop-filter:blur(40px) saturate(210%);-webkit-backdrop-filter:blur(40px) saturate(210%);border:1px solid rgba(255,255,255,.97);border-radius:var(--r-2xl);box-shadow:var(--sh-lg);width:100%;animation:fadeUp .2s ease both;overflow:hidden;max-height:90vh;display:flex;flex-direction:column}
.mhd{padding:20px 22px 14px;border-bottom:1px solid rgba(255,255,255,.55);display:flex;align-items:flex-start;justify-content:space-between;flex-shrink:0}
.mtit{font-size:18px;font-weight:800;color:var(--t900);letter-spacing:-.3px}
.msub{font-size:12px;color:var(--t400);margin-top:3px}
.mclose{background:rgba(100,116,139,.09);border:none;color:var(--t400);width:30px;height:30px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all .12s;flex-shrink:0}
.mclose:hover{background:rgba(100,116,139,.18);color:var(--t700)}
.mbody{padding:18px 22px;overflow-y:auto;flex:1;min-height:0}
.mfoot{padding:12px 22px 18px;border-top:1px solid rgba(255,255,255,.55);display:flex;gap:8px;justify-content:flex-end;flex-shrink:0}
.btn-can{background:rgba(100,116,139,.08);border:1px solid rgba(100,116,139,.14);color:var(--t500);padding:9px 17px;border-radius:var(--r-sm);font-size:13px;font-weight:600;cursor:pointer;transition:all .13s}
.btn-can:hover{border-color:rgba(100,116,139,.28);color:var(--t700)}
.btn-cf{background:linear-gradient(135deg,var(--navy),#1D4ED8);border:none;color:#fff;padding:9px 20px;border-radius:var(--r-sm);font-size:13px;font-weight:700;cursor:pointer;transition:all .14s;box-shadow:0 3px 10px rgba(15,36,95,.26)}
.btn-cf:hover{transform:translateY(-1px);box-shadow:0 5px 14px rgba(15,36,95,.36)}
/* packs */
.packs{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:14px}
.pack{background:rgba(255,255,255,.52);border:1.5px solid rgba(255,255,255,.78);border-radius:var(--r-lg);padding:13px 9px;cursor:pointer;text-align:center;transition:all .17s;backdrop-filter:blur(8px)}
.pack:hover{background:rgba(255,255,255,.72);border-color:rgba(194,130,10,.28)}
.pack.sel{border-color:rgba(194,130,10,.5);background:rgba(194,130,10,.06);box-shadow:0 0 0 3px rgba(194,130,10,.09)}
.pemoji{font-size:22px;margin-bottom:4px}
.pamt{font-size:21px;font-weight:800;color:var(--sa);margin-bottom:2px}
.plbl_{font-size:9px;color:var(--t400);text-transform:uppercase;letter-spacing:.6px;font-weight:700;margin-bottom:6px}
.pprice{font-family:var(--fm);font-size:12px;padding:2px 8px;border-radius:9px;background:rgba(100,116,139,.08);color:var(--t500);display:inline-block}
.pack.sel .pprice{background:rgba(194,130,10,.11);color:var(--st)}
.balrow{background:rgba(255,255,255,.5);border:1px solid rgba(255,255,255,.78);border-radius:var(--r-md);padding:11px 14px;display:flex;align-items:center;justify-content:space-between}
.ballbl{font-size:11px;font-weight:600;color:var(--t500)}
.balval{font-family:var(--fm);font-size:17px;font-weight:700;color:var(--sa);display:flex;align-items:center;gap:5px}
/* compare table */
#cmpModal .mbox{max-width:940px}
.ctw{overflow-x:auto}
.ctbl{width:100%;border-collapse:collapse;font-size:12px}
.ctbl th{padding:11px 13px;text-align:left;font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--t500);background:rgba(255,255,255,.38);border-bottom:1.5px solid rgba(255,255,255,.65);white-space:nowrap}
.ctbl td{padding:11px 13px;border-bottom:1px solid rgba(100,116,139,.07);color:var(--t700);line-height:1.5;vertical-align:top}
.ctbl tr:last-child td{border-bottom:none}
.ctbl tbody tr:hover td{background:rgba(255,255,255,.3)}
.ctbl td:first-child{font-weight:700;color:var(--t500);font-size:11px;white-space:nowrap}
.cq{background:rgba(2,132,199,.022)}.cs{background:rgba(194,130,10,.022)}.crr{background:rgba(124,58,237,.022)}
.th-inner{display:flex;align-items:center;gap:6px;margin-bottom:5px;font-size:12px;font-weight:800}
.th-q .th-inner{color:var(--qt)}.th-s .th-inner{color:var(--st)}.th-r .th-inner{color:var(--rt)}
.cpill{display:inline-flex;align-items:center;gap:3px;font-family:var(--fm);font-size:10px;font-weight:700;padding:2px 8px;border-radius:8px}
.cpq{background:var(--qb);color:var(--qt);border:1px solid var(--qbd)}.cps{background:var(--sb);color:var(--st);border:1px solid var(--sbd)}.cpr_{background:var(--rb);color:var(--rt);border:1px solid var(--rbd)}
.tftag{display:inline-flex;font-family:var(--fm);font-size:10px;font-weight:700;padding:2px 7px;border-radius:5px;margin:2px}
.hl{display:flex;flex-direction:column;gap:2px;font-size:11px}
.hl span{display:flex;gap:5px;align-items:baseline}
.hltf{font-family:var(--fm);font-weight:700;font-size:10px}
.chy{color:var(--ok)}.chn{color:var(--t300)}
.pri-std{color:var(--t500);font-weight:600}.pri-fast{color:var(--qa);font-weight:700}.pri-top{color:var(--ra);font-weight:700}
.mono-v{font-family:var(--fm);font-weight:600;color:var(--t800)}
/* ══════════ TOAST ══════════ */
.toast{position:fixed;bottom:22px;right:22px;background:rgba(255,255,255,.88);backdrop-filter:var(--blur);border:1px solid rgba(220,38,38,.22);border-radius:var(--r-lg);padding:11px 14px;display:none;align-items:center;gap:11px;box-shadow:0 8px 24px rgba(220,38,38,.1);z-index:1000;max-width:310px}
.toast.show{display:flex;animation:fadeUp .2s ease both}
.tico{color:var(--er);font-size:17px;flex-shrink:0}
.tbody_{flex:1}
.tttl{font-size:13px;font-weight:700;color:var(--t900);margin-bottom:2px}
.tmsg_{font-size:11px;color:var(--t500)}
.tcls{background:none;border:none;color:var(--t400);cursor:pointer;font-size:13px;transition:color .11s}
.tcls:hover{color:var(--t700)}
/* ══════════ RESPONSIVE ══════════ */
@media(max-width:1160px){.r2{grid-template-columns:1fr}.stat-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:900px){
html,body{height:auto;overflow:auto}
#shell{height:auto;overflow:visible}
.app-row{flex-direction:column;height:auto;overflow:visible}
.sidebar{width:100%!important;height:auto;overflow:visible}
.sb-scroll{overflow:visible;height:auto}
.term-wrap{height:200px}
.main{overflow:visible;padding:14px}
.stat-grid{grid-template-columns:repeat(2,1fr)}
.write-panel{max-width:100%;height:88vh}
