function updWrRing() {
var w = wc(stratText), mx = PLANS[curPlan].maxWords;
var circ = 2 * Math.PI * 16;
var pct = Math.min((w/mx)*100, 100);
var offset = circ - (pct/100) * circ;
var fill = document.getElementById('ringFill');
fill.style.strokeDasharray = circ + ' ' + circ;
fill.style.strokeDashoffset = offset;
fill.style.stroke = w > mx ? '#DC2626' : w > mx*.85 ? '#D97706' : 'var(--navy)';
document.getElementById('wrBig').textContent = w;
document.getElementById('wrBig').style.color = w > mx ? '#DC2626' : w > mx*.85 ? '#D97706' : 'var(--t900)';
document.getElementById('wrSub').textContent = '/ ' + mx + ' words';
document.getElementById('wrHint').textContent = w > mx ? '⚠ Over the word limit' : w > mx*.85 ? 'Getting close to the limit' : 'Describe entry, exit & risk rules';
}
function updWrMeta() {
var pl = PLANS[curPlan];
var validA = assets.filter(function(a){return a.trim();});
var h = pl.history[curTf] || '';
var parts = [
'<div class="wr-meta-chip"><i class="fa-solid '+pl.icon+'"></i>'+escH(pl.name)+'</div>'
];
if (validA.length) parts.push('<div class="wr-meta-chip"><i class="fa-solid fa-coins"></i>'+escH(validA.join(', '))+'</div>');
if (curTf) parts.push('<div class="wr-meta-chip"><i class="fa-solid fa-clock"></i>'+curTf+'</div>');
if (h) parts.push('<div class="wr-meta-chip"><i class="fa-solid fa-database"></i>'+escH(h)+'</div>');
if (indicators.length) parts.push('<div class="wr-meta-chip"><i class="fa-solid fa-chart-simple"></i>'+escH(indicators.join(' · '))+'</div>');
document.getElementById('wrMeta').innerHTML = parts.join('');
}
