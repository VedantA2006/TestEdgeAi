async function runBT() {
console.log('🚀 runBT() called');

// Reset previous results
pdata = {yearly: [], monthly: [], metrics: {}};
lastCode = '';
document.getElementById('eqImg').src = '';
document.getElementById('eqCard').style.display = 'none';
document.getElementById('retGrid').style.display = 'none';
document.getElementById('codeCard').style.display = 'none';

