function parseMo(s){s=s.trim();var m1=s.match(/^([a-z]{3})-(\d{4})%?$/i);if(m1){var i=MONTHS[m1[1].toLowerCase()];if(i!==undefined)return{year:m1[2],monthIndex:i};}if(/^\d{4}-\d{1,2}$/.test(s)){var p=s.split('-'),i=parseInt(p[1])-1;if(i>=0&&i<12)return{year:p[0],monthIndex:i};}if(/^\d{4}-\d{2}-\d{2}$/.test(s)){var p=s.split('-'),i=parseInt(p[1])-1;if(i>=0&&i<12)return{year:p[0],monthIndex:i};}var m2=s.match(/^([a-z]+)\s+(\d{4})%?$/i);if(m2){var i=MONTHS[m2[1].toLowerCase()];if(i!==undefined)return{year:m2[2],monthIndex:i};}return null;}
function updStats(m){var g=function(k){return m[k]||'--';};var rv=g('Total Return (%)'),re=document.getElementById('sR');re.textContent=rv;re.className='sv'+(parseFloat(rv)>=0?' pos':' neg');var cv=g('CAGR (%)'),ce=document.getElementById('sC');ce.textContent=cv;ce.className='sv'+(parseFloat(cv)>=0?' pos':' neg');document.getElementById('sD').textContent=g('Max Drawdown (%)');document.getElementById('sD').className='sv neg';document.getElementById('sT').textContent=g('Total Trades');document.getElementById('srow').style.display='grid';}
function renderYr(){var ctx=document.getElementById('yrChart').getContext('2d');if(yrChart)yrChart.destroy();var lb=pdata.yearly.map(function(d){return d.year;}),vs=pdata.yearly.map(function(d){return d.value;}),cols=vs.map(function(v){return v>=0?'rgba(5,150,105,.82)':'rgba(220,38,38,.82)';});yrChart=new Chart(ctx,{type:'bar',data:{labels:lb,datasets:[{label:'Return (%)',data:vs,backgroundColor:cols,borderRadius:6,borderSkipped:false,barThickness:30}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#0D1117',titleColor:'#E6EDF3',bodyColor:'#8B949E',padding:10,cornerRadius:8,callbacks:{label:function(c){return c.parsed.y.toFixed(2)+'%';}}}},scales:{y:{beginAtZero:false,grid:{color:'rgba(100,116,139,.08)'},ticks:{color:'#94A3B8',font:{size:11,family:"'JetBrains Mono'"},callback:function(v){return v+'%';}}},x:{grid:{display:false},ticks:{color:'#94A3B8',font:{size:11,family:"'JetBrains Mono'"}}}}}})}
function renderHM(){var cont=document.getElementById('hmCont');var MH=['J','F','M','A','M','J','J','A','S','O','N','D'];if(!pdata.monthly.length){cont.innerHTML='<div style="padding:28px;text-align:center;color:var(--t400)">No monthly data</div>';return;}var yd={};pdata.monthly.forEach(function(d){if(!yd[d.year])yd[d.year]=new Array(12).fill(null);yd[d.year][d.monthIndex]=d.value;});var years=Object.keys(yd).sort();var h='<div class="hmg"><div class="hmc0"></div>';MH.forEach(function(m){h+='<div class="hmmh">'+m+'</div>';});years.forEach(function(yr){h+='<div class="hmyr">'+yr+'</div>';for(var j=0;j<12;j++){var v=yd[yr][j];if(v===null||v===undefined){h+='<div class="hmcell nil"></div>';}else{var cl=hmC(v),cs=v>=0?'pos':'neg',dv=v>=0?'+'+v.toFixed(0):v.toFixed(0);h+='<div class="hmcell '+cs+'" style="background:'+cl+'" title="'+yr+' M'+(j+1)+': '+v.toFixed(2)+'%">'+dv+'</div>';}}});cont.innerHTML=h+'</div>';tlog('✅ Heatmap ready','s');}
function hmC(v){if(v<-3)return'#DC2626';if(v<-1)return'#F87171';if(v<0)return'#FCA5A5';if(v===0)return'#E2E8F0';if(v<1)return'#86EFAC';if(v<3)return'#22C55E';return'#15803D';}
function mkSkel(){var h='<div class="ml">';['Start Date','End Date','Timeframe','Total Return (%)','CAGR (%)','Max Drawdown (%)','Win Rate (%)','Profit Factor','Sharpe Ratio','Total Trades'].forEach(function(r){h+='<div class="mr"><span class="mk">'+escH(r)+'</span><span class="skel" style="width:72px;height:15px"></span></div>';});return h+'</div>';}
