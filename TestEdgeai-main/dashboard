function rebuildTags() {
var box = document.getElementById('tagBox');
var inp = document.getElementById('tagInput');
box.querySelectorAll('.tag-chip').forEach(function(c) { c.remove(); });
var pl = PLANS[curPlan];
indicators.forEach(function(name, idx) {
var chip = document.createElement('div');
chip.className = 'tag-chip ' + pl.cls;
var xBtn = document.createElement('button');
xBtn.className = 't-x';
xBtn.type = 'button';
xBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
(function(i) { xBtn.addEventListener('click', function(e) { e.stopPropagation(); removeTag(i); }); })(idx);
chip.appendChild(document.createTextNode(name));
chip.appendChild(xBtn);
box.insertBefore(chip, inp);
});
var atLimit = indicators.length >= pl.maxInds;
inp.placeholder = atLimit ? 'Limit reached' : 'Type indicator, press Enter';
inp.disabled = atLimit;
}
function tagKeydown(e) {
var val = e.target.value.trim().replace(/,/g,'');
if ((e.key === 'Enter' || e.key === ',') && val) {
e.preventDefault();
addTag(val);
e.target.value = '';
}
if (e.key === 'Backspace' && !e.target.value && indicators.length > 0) {
removeTag(indicators.length - 1);
}
}
function tagOnInput() {
var val = document.getElementById('tagInput').value;
if (val.endsWith(',')) {
var name = val.replace(/,/g,'').trim();
if (name) addTag(name);
document.getElementById('tagInput').value = '';
}
}
function addTag(name) {
name = name.toUpperCase().trim();
var pl = PLANS[curPlan];
if (!name || indicators.length >= pl.maxInds) return;
if (indicators.map(function(s){return s.toLowerCase();}).indexOf(name.toLowerCase()) !== -1) return;
indicators.push(name);
rebuildTags();
updWrMeta();
}
function removeTag(idx) {
indicators.splice(idx, 1);
rebuildTags();
updWrMeta();
}
