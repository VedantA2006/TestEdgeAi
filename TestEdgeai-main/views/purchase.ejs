            <i class="fas fa-circle-notch fa-spin text-4xl text-brand-500 mb-4"></i>
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">Processing Payment</h3>
            <p class="text-sm text-slate-500">Please do not close or refresh this window.</p>
        </div>
