    <div id="toast" class="toast-popup fixed bottom-6 right-6 bg-white dark:bg-[#161618] border border-slate-200 dark:border-white/10 rounded-xl shadow-2xl p-4 flex items-start gap-3 z-[200] max-w-sm">
        <div id="toastIcon" class="mt-0.5 text-lg"></div>
        <div class="flex-1">
            <h4 id="toastTitle" class="text-sm font-bold text-slate-900 dark:text-white mb-0.5">Notification</h4>
            <p id="tmsg" class="text-xs text-slate-500 dark:text-slate-400">Message goes here</p>
        </div>
        <button onclick="closeToast()" class="text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors">
            <i class="fas fa-xmark"></i>
        </button>
    </div>

    <script>
        let currentPackage = null;
        let toastTimer = null;

        // Theme Toggle Setup
        document.getElementById('themeToggle').addEventListener('click', () => {
            document.documentElement.classList.toggle('dark');
            localStorage.theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
        });

        // ════ Razorpay & Purchase Logic (Preserved) ════
        async function buyPackage(pkgKey) {
            currentPackage = pkgKey;
            showLoading(true);

            try {
                console.log('📦 Purchasing package:', pkgKey);
                
                const res = await fetch('/purchase/create-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ package: pkgKey })
                });

                const data = await res.json();
                console.log('📥 Response:', data);

                if (!res.ok || !data.success) {
                    throw new Error(data.error || 'Failed to create order');
                }

                // Check Dark Mode to style Razorpay Modal
                const isDark = document.documentElement.classList.contains('dark');
                const themeColor = isDark ? '#14b8a6' : '#0F2444'; // Brand color or Navy

                // Open Razorpay Checkout
                const options = {
                    key: data.order.key_id,
                    amount: data.order.amount,
                    currency: data.order.currency,
                    name: data.order.name,
                    description: data.order.description,
                    order_id: data.order.id,
                    prefill: {
                        name: data.order.prefill.name,
                        email: data.order.prefill.email,
                        contact: ''
                    },
                    theme: {
                        color: themeColor
                    },
                    handler: function(response) {
                        handlePaymentSuccess(response, data.order);
                    },
                    modal: {
                        ondismiss: function() {
                            showLoading(false);
                            showToast('Payment cancelled', 'er');
                        }
                    }
                };

                const rzp = new Razorpay(options);
                
                rzp.on('payment.failed', function(response) {
                    showLoading(false);
                    console.error('Payment failed:', response);
                    showToast('Payment failed: ' + (response.error?.description || 'Unknown error'), 'er');
                });

                rzp.open();
            } catch (err) {
                showLoading(false);
                console.error('Error:', err);
                showToast('Error: ' + err.message, 'er');
            }
        }

        async function handlePaymentSuccess(response, orderData) {
            try {
                const res = await fetch('/purchase/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        razorpay_order_id: response.razorpay_order_id,
                        razorpay_payment_id: response.razorpay_payment_id,
                        razorpay_signature: response.razorpay_signature,
                        package: orderData.package
                    })
                });

                const data = await res.json();

                if (data.success) {
                    showLoading(false);
                    showToast('✓ Payment successful! ' + data.credits + ' credits added', 'ok');
                    setTimeout(() => {
                        window.location.href = '/purchase/success?transaction_id=' + data.transactionId + '&credits=' + data.credits;
                    }, 1500);
                } else {
                    throw new Error(data.error || 'Verification failed');
                }
            } catch (err) {
                showLoading(false);
                console.error('Verification error:', err);
                showToast('Verification failed. Contact support with payment ID: ' + response.razorpay_payment_id, 'er');
            }
        }

        // ════ UI Helper Functions ════
        function showLoading(show) {
            const overlay = document.getElementById('loadingOverlay');
            if (overlay) {
                if (show) overlay.classList.add('show');
                else overlay.classList.remove('show');
            }
        }

        function showToast(msg, type) {
            const toast = document.getElementById('toast');
            const icon = document.getElementById('toastIcon');
            const title = document.getElementById('toastTitle');
            const message = document.getElementById('tmsg');
            
            if(type === 'ok') {
                icon.innerHTML = '<i class="fas fa-circle-check text-brand-500"></i>';
                title.textContent = 'Success';
                toast.classList.replace('border-red-500/20', 'border-brand-500/20');
            } else {
                icon.innerHTML = '<i class="fas fa-circle-exclamation text-red-500"></i>';
                title.textContent = 'Error';
                toast.classList.replace('border-brand-500/20', 'border-red-500/20');
            }
            
            message.textContent = msg;
            toast.classList.add('show');
            
            clearTimeout(toastTimer);
            toastTimer = setTimeout(closeToast, 4000);
        }

        function closeToast() {
            document.getElementById('toast').classList.remove('show');
        }
    </script>
