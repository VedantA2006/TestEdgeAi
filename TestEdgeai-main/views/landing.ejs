    <script>
        // Wait for DOM to be ready
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Animations
            AOS.init({ once: true, offset: 50 });

            // Dark Mode Toggle Logic
            const html = document.documentElement;
            const themeBtn = document.getElementById('themeToggle');
            
            // Default to dark mode if not set
            if (!localStorage.getItem('theme')) localStorage.setItem('theme', 'dark');
            
            if (localStorage.theme === 'dark') html.classList.add('dark');
            else html.classList.remove('dark');

            if (themeBtn) {
                themeBtn.addEventListener('click', () => {
                    html.classList.toggle('dark');
                    localStorage.theme = html.classList.contains('dark') ? 'dark' : 'light';
                });
            }

            // Smooth Scroll for Anchor Links
            document.querySelectorAll('a.smooth-scroll, a[href^="#"]:not([href="#"])').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
                    
                    // Only handle anchor links (starting with #)
                    if (href && href.startsWith('#')) {
                        const targetId = href.substring(1);
                        const targetElement = document.getElementById(targetId);
                        
                        if (targetElement) {
                            e.preventDefault();
                            targetElement.scrollIntoView({
                                behavior: 'smooth',
                                block: 'start'
                            });
                        }
                    }
                    // Let other links (like /auth/login, mailto:, etc.) work normally
                });
            });

            // FAQ Accordion Logic
            document.querySelectorAll('.faq-btn').forEach(button => {
                button.addEventListener('click', () => {
                    const content = button.nextElementSibling;
                    const icon = button.querySelector('i');
                    content.classList.toggle('hidden');
                    icon.style.transform = content.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
                });
            });

            // Contact Form Mailto Logic
            const contactForm = document.getElementById('contactForm');
            if (contactForm) {
                contactForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    const data = Object.fromEntries(new FormData(this));
                    const subject = encodeURIComponent(`Inquiry: ${data.subject}`);
                    const body = encodeURIComponent(`From: ${data.name} (${data.email})\n\n${data.message}`);
                    window.location.href = `mailto:sameetpisal@gmail.com?subject=${subject}&body=${body}`;
                });
            }
        });
    </script>
