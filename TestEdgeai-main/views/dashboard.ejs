<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QuantAI Studio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        /* ══════════ TOKENS & RESET ══════════ */
        :root {
            --bg: #EEF2F7;
            --glass-a: rgba(255, 255, 255, .55);
            --glass-b: rgba(255, 255, 255, .75);
            --glass-c: rgba(255, 255, 255, .88);
            --glass-nav: rgba(255, 255, 255, .80);
            --bdr: rgba(255, 255, 255, .85);
            --bdr2: rgba(255, 255, 255, .95);
            --blur: blur(24px) saturate(180%);
            --sh-sm: 0 2px 12px rgba(15, 23, 42, .07), inset 0 1px 0 rgba(255, 255, 255, .85);
            --sh-md: 0 6px 24px rgba(15, 23, 42, .09), inset 0 1px 0 rgba(255, 255, 255, .9);
            --sh-lg: 0 16px 48px rgba(15, 23, 42, .12), inset 0 1px 0 rgba(255, 255, 255, .95);
            --navy: #0F2444;
            --qa: #0284C7;
            --qb: rgba(2, 132, 199, .09);
            --qbd: rgba(2, 132, 199, .3);
            --qt: #025C8F;
            --sa: #C2820A;
            --sb: rgba(194, 130, 10, .09);
            --sbd: rgba(194, 130, 10, .3);
            --st: #7A520A;
            --ra: #7C3AED;
            --rb: rgba(124, 58, 237, .09);
            --rbd: rgba(124, 58, 237, .3);
            --rt: #5B21B6;
            --ok: #059669;
            --okb: rgba(5, 150, 105, .1);
            --okbd: rgba(5, 150, 105, .3);
            --er: #DC2626;
            --erb: rgba(220, 38, 38, .1);
            --erbd: rgba(220, 38, 38, .3);
            --wn: #D97706;
            --wnb: rgba(217, 119, 6, .1);
            --t900: #060F1F;
            --t800: #1A2942;
            --t700: #334155;
            --t600: #475569;
            --t500: #64748B;
            --t400: #94A3B8;
            --t300: #CBD5E1;
            --t200: #E2E8F0;
            --r-xs: 6px;
            --r-sm: 8px;
            --r-md: 12px;
            --r-lg: 16px;
            --r-xl: 20px;
            --r-2xl: 26px;
            --fs: 'DM Sans', system-ui, sans-serif;
            --fm: 'JetBrains Mono', monospace;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html,
        body {
            height: 100%;
            overflow: hidden
        }

        body {
            font-family: var(--fs);
            background: var(--bg);
            color: var(--t700);
            -webkit-font-smoothing: antialiased;
            position: relative
        }

        a {
            text-decoration: none;
            color: inherit
        }

        button,
        input,
        textarea,
        select {
            font-family: var(--fs)
        }

        ::-webkit-scrollbar {
            width: 4px;
            height: 4px
        }

        ::-webkit-scrollbar-track {
            background: transparent
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(100, 116, 139, .25);
            border-radius: 4px
        }

        /* ══════════ BACKGROUND & ANIMATIONS ══════════ */
        #bgMesh {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background:
                radial-gradient(ellipse 70% 55% at 10% 35%, rgba(2, 132, 199, .13) 0%, transparent 60%),
                radial-gradient(ellipse 55% 50% at 88% 18%, rgba(124, 58, 237, .09) 0%, transparent 55%),
                radial-gradient(ellipse 45% 65% at 65% 92%, rgba(15, 36, 68, .07) 0%, transparent 55%),
                radial-gradient(ellipse 35% 35% at 45% 55%, rgba(5, 150, 105, .05) 0%, transparent 45%),
                linear-gradient(145deg, #EBF4FF 0%, #F5F7FA 45%, #EEF0F5 100%);
        }

        @keyframes fadeIn {
            from {
                opacity: 0
            }

            to {
                opacity: 1
            }
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(14px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        @keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-16px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1
            }

            50% {
                opacity: .3
            }
        }

        @keyframes spin {
            to {
                transform: rotate(360deg)
            }
        }

        @keyframes shimmer {
            0% {
                background-position: -200% 0
            }

            100% {
                background-position: 200% 0
            }
        }

        @keyframes floatUp {

            0%,
            100% {
                transform: translateY(0)
            }

            50% {
                transform: translateY(-6px)
            }
        }

        @keyframes popIn {
            0% {
                opacity: 0;
                transform: scale(.85)
            }

            100% {
                opacity: 1;
                transform: scale(1)
            }
        }

        @keyframes slideUp {
            from {
                transform: translateY(100%)
            }

            to {
                transform: translateY(0)
            }
        }

        /* ══════════ LAYOUT SHELL & COMPONENT STYLES ══════════ */
        /* Note: For brevity, keeping all the exact CSS from your prompt. 
           It is identical to your original styles. */
        #shell {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            isolation: isolate;
        }

        .nav {
            flex-shrink: 0;
            height: 58px;
            background: var(--glass-nav);
            backdrop-filter: var(--blur);
            -webkit-backdrop-filter: var(--blur);
            border-bottom: 1px solid var(--bdr);
            box-shadow: 0 2px 10px rgba(15, 23, 42, .06), inset 0 -1px 0 rgba(255, 255, 255, .5);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 22px;
            position: relative;
            z-index: 100;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px
        }

        .blogo {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, var(--navy), #0284C7);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 15px;
            box-shadow: 0 3px 10px rgba(2, 132, 199, .28), inset 0 1px 0 rgba(255, 255, 255, .2);
        }

        .bname {
            font-size: 16px;
            font-weight: 800;
            color: var(--navy);
            letter-spacing: -.5px
        }

        .bname em {
            color: var(--qa);
            font-style: normal
        }

        .nav-r {
            display: flex;
            align-items: center;
            gap: 8px
        }

        .eng-pill {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .5px;
            color: var(--ok);
            background: var(--okb);
            border: 1px solid var(--okbd);
            padding: 5px 11px;
            border-radius: 20px;
            font-family: var(--fm)
        }

        .pdot {
            width: 5px;
            height: 5px;
            background: var(--ok);
            border-radius: 50%;
            animation: pulse 2s infinite
        }

        .cr-pill {
            display: flex;
            align-items: center;
            gap: 7px;
            background: rgba(194, 130, 10, .08);
            border: 1px solid rgba(194, 130, 10, .22);
            border-radius: 24px;
            padding: 4px 5px 4px 12px;
            cursor: pointer;
            transition: all .18s
        }

        .cr-pill:hover {
            border-color: var(--sa);
            box-shadow: 0 2px 10px rgba(194, 130, 10, .14)
        }

        .cr-info {
            display: flex;
            flex-direction: column;
            line-height: 1
        }

        .cr-lbl {
            font-size: 8px;
            font-weight: 700;
            color: var(--st);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 1px
        }

        .cr-val {
            font-family: var(--fm);
            font-size: 14px;
            font-weight: 700;
            color: var(--sa)
        }

        .btn-buy {
            background: linear-gradient(135deg, var(--sa), #F59E0B);
            color: #fff;
            border: none;
            padding: 5px 11px;
            border-radius: 18px;
            font-size: 11px;
            font-weight: 700;
            cursor: pointer;
            transition: all .15s;
            display: flex;
            align-items: center;
            gap: 4px;
            box-shadow: 0 2px 8px rgba(194, 130, 10, .28)
        }

        .btn-buy:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(194, 130, 10, .38)
        }

        .nav-menu {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            flex: 1 1 320px;
            min-width: 0;
            flex-wrap: wrap
        }

        .nav-link {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 13px;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, .18);
            background: rgba(255, 255, 255, .38);
            color: var(--t600);
            font-size: 13px;
            font-weight: 700;
            white-space: nowrap;
            transition: background .18s, border-color .18s, color .18s, transform .18s, box-shadow .18s
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, .7);
            border-color: rgba(2, 132, 199, .24);
            color: var(--navy);
            box-shadow: var(--sh-sm);
            transform: translateY(-1px)
        }

        .nav-link i {
            color: var(--t400);
            font-size: 12px;
            transition: color .18s
        }

        .nav-link:hover i,
        .nav-link.is-active i {
            color: var(--qa)
        }

        .nav-link.is-active {
            color: var(--navy);
            background: rgba(2, 132, 199, .1);
            border-color: rgba(2, 132, 199, .22);
            box-shadow: 0 4px 14px rgba(2, 132, 199, .12)
        }

        .nav-link.danger {
            color: var(--er);
            background: rgba(220, 38, 38, .05);
            border-color: rgba(220, 38, 38, .12)
        }

        .nav-link.danger i,
        .nav-link.danger:hover i {
            color: var(--er)
        }

        .nav-link.danger:hover {
            background: rgba(220, 38, 38, .1);
            border-color: rgba(220, 38, 38, .22);
            color: var(--er)
        }

        .nav-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 12px;
            flex-wrap: wrap
        }

        .nav-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 4px 12px 4px 4px;
            border-radius: 24px;
            border: 1px solid var(--bdr);
            background: var(--glass-a);
            backdrop-filter: blur(12px);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, .55)
        }

        .nav-user-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--navy), var(--qa));
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            box-shadow: 0 2px 6px rgba(2, 132, 199, .25)
        }

        .nav-user-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--t700);
            max-width: 120px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap
        }

        .app-row {
            display: flex;
            flex: 1;
            min-height: 0;
            position: relative
        }

        .sidebar {
            width: 420px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            background: var(--glass-a);
            backdrop-filter: var(--blur);
            border-right: 1px solid var(--bdr);
            box-shadow: 2px 0 16px rgba(15, 23, 42, .05), inset -1px 0 0 rgba(255, 255, 255, .45);
            transition: width .4s cubic-bezier(.4, 0, .2, 1);
            position: relative;
            z-index: 10;
            animation: slideInLeft .4s ease both;
        }

        .sidebar.mini {
            width: 64px
        }

        .sb-scroll {
            flex: 1;
            min-height: 0;
            overflow-y: auto;
            overflow-x: hidden
        }

        .sb-form {
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 14px
        }

        .sidebar.mini .sb-form {
            display: none
        }

        .sb-rail {
            display: none;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            padding: 12px 0
        }

        .sidebar.mini .sb-rail {
            display: flex
        }

        .rail-ico {
            width: 40px;
            height: 40px;
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            border: 1px solid rgba(255, 255, 255, .65);
            background: rgba(255, 255, 255, .45);
            color: var(--t500);
            cursor: pointer;
            transition: all .15s
        }

        .rail-ico:hover {
            background: var(--glass-b);
            color: var(--t900);
            box-shadow: var(--sh-sm)
        }

        .rail-ico.act {
            color: var(--qa);
            background: rgba(2, 132, 199, .1);
            border-color: rgba(2, 132, 199, .3)
        }

        .rail-sep {
            width: 28px;
            height: 1px;
            background: rgba(100, 116, 139, .18);
            margin: 2px 0
        }

        .run-wrap {
            flex-shrink: 0;
            padding: 12px 16px;
            border-top: 1px solid rgba(255, 255, 255, .5);
            background: rgba(255, 255, 255, .25);
            display: flex;
            flex-direction: column;
            gap: 9px
        }

        .sidebar.mini .run-full {
            display: none
        }

        .sidebar.mini .run-wrap {
            padding: 8px;
            align-items: center
        }

        .run-mini-btn {
            display: none
        }

        .sidebar.mini .run-mini-btn {
            display: flex;
            width: 40px;
            height: 40px;
            border-radius: 11px;
            border: none;
            background: linear-gradient(135deg, var(--navy), #1D4ED8);
            color: #fff;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            cursor: pointer;
            box-shadow: 0 3px 10px rgba(15, 36, 95, .28);
            transition: all .15s
        }

        .sidebar.mini .run-mini-btn:hover {
            transform: scale(1.07)
        }

        .cost-glass {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255, 255, 255, .45);
            border: 1px solid rgba(255, 255, 255, .8);
            border-radius: var(--r-md);
            padding: 9px 12px
        }

        .cost-t {
            font-size: 12px;
            font-weight: 600;
            color: var(--t700)
        }

        .cost-s {
            font-size: 10px;
            color: var(--t400);
            margin-top: 1px
        }

        .cost-b {
            display: flex;
            align-items: center;
            gap: 4px;
            font-family: var(--fm);
            font-size: 16px;
            font-weight: 700
        }

        .btn-run {
            width: 100%;
            border: none;
            padding: 12px 20px;
            border-radius: var(--r-md);
            font-weight: 800;
            font-size: 14px;
            color: #fff;
            cursor: pointer;
            background: linear-gradient(135deg, #0F2444 0%, #1D4ED8 60%, #0284C7 100%);
            background-size: 200% 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all .25s;
            letter-spacing: .15px;
            box-shadow: 0 4px 16px rgba(15, 36, 95, .28), inset 0 1px 0 rgba(255, 255, 255, .15);
        }

        .btn-run:hover:not(:disabled) {
            background-position: 100% 0;
            transform: translateY(-2px);
            box-shadow: 0 7px 24px rgba(15, 36, 95, .38)
        }

        .btn-run:disabled {
            opacity: .5;
            cursor: not-allowed;
            transform: none
        }

        .btn-run .bspin {
            width: 14px;
            height: 14px;
            border: 2.5px solid rgba(255, 255, 255, .3);
            border-right-color: #fff;
            border-radius: 50%;
            animation: spin .6s linear infinite;
            flex-shrink: 0
        }

        .ptrk {
            height: 4px;
            background: rgba(100, 116, 139, .14);
            border-radius: 3px;
            overflow: hidden;
            transition: opacity .3s
        }

        .ptrk.hid {
            opacity: 0;
            pointer-events: none
        }

        .pfill {
            height: 100%;
            background: linear-gradient(90deg, var(--qa), #818CF8);
            background-size: 200% 100%;
            border-radius: 3px;
            width: 0%;
            transition: width .5s ease;
            animation: shimmer 2s linear infinite
        }

        .p-note {
            font-size: 9.5px;
            font-family: var(--fm);
            color: var(--t400);
            min-height: 13px
        }

        .term-wrap {
            flex-shrink: 0;
            height: 210px;
            display: flex;
            flex-direction: column;
            border-top: 1px solid rgba(255, 255, 255, .25)
        }

        .sidebar.mini .term-wrap {
            height: calc(100% - 64px - 64px);
            min-height: 100px
        }

        .term-bar {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 7px 12px;
            background: #13181F;
            border-bottom: 1px solid rgba(255, 255, 255, .06)
        }

        .tdots {
            display: flex;
            gap: 4px
        }

        .td {
            width: 9px;
            height: 9px;
            border-radius: 50%
        }

        .td:nth-child(1) {
            background: #FF5F57
        }

        .td:nth-child(2) {
            background: #FFBD2E
        }

        .td:nth-child(3) {
            background: #28C840
        }

        .t-title {
            font-family: var(--fm);
            font-size: 9px;
            font-weight: 600;
            color: #6E7681;
            text-transform: uppercase;
            letter-spacing: .9px;
            display: flex;
            align-items: center;
            gap: 6px
        }

        .t-title i {
            color: #58A6FF;
            font-size: 10px
        }

        .btn-clr {
            background: rgba(255, 255, 255, .04);
            border: 1px solid rgba(255, 255, 255, .08);
            font-size: 9px;
            font-weight: 600;
            color: #6E7681;
            cursor: pointer;
            padding: 3px 8px;
            border-radius: 4px;
            font-family: var(--fm);
            transition: all .14s;
            display: flex;
            align-items: center;
            gap: 4px
        }

        .btn-clr:hover {
            background: rgba(255, 255, 255, .09);
            color: #C9D1D9
        }

        .term-body {
            flex: 1;
            min-height: 0;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 8px 12px;
            font-family: var(--fm);
            font-size: 11px;
            line-height: 1.9;
            background: #0D1117
        }

        .term-body::-webkit-scrollbar {
            width: 3px
        }

        .term-body::-webkit-scrollbar-thumb {
            background: #21262D;
            border-radius: 3px
        }

        .tline {
            display: flex;
            gap: 8px;
            align-items: flex-start;
            animation: fadeIn .18s ease both
        }

        .tts {
            color: #30363D;
            font-size: 9px;
            margin-top: .25em;
            flex-shrink: 0;
            user-select: none
        }

        .tmsg {
            word-break: break-all
        }

        .t-i {
            color: #8B949E
        }

        .t-s {
            color: #3FB950;
            font-weight: 600
        }

        .t-e {
            color: #F85149;
            font-weight: 600
        }

        .t-w {
            color: #E3B341;
            font-weight: 500
        }

        .t-b {
            color: #E6EDF3;
            font-weight: 700
        }

        .t-c {
            color: #79C0FF
        }

        .sec-lbl {
            font-size: 9.5px;
            font-weight: 800;
            color: var(--t400);
            text-transform: uppercase;
            letter-spacing: 1.1px;
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 8px
        }

        .sec-lbl i {
            font-size: 11px;
            color: var(--t600)
        }

        .plan-row {
            display: flex;
            gap: 6px
        }

        .pp {
            flex: 1;
            padding: 10px 6px 8px;
            border-radius: var(--r-md);
            background: rgba(255, 255, 255, .45);
            border: 1.5px solid rgba(255, 255, 255, .7);
            cursor: pointer;
            text-align: center;
            transition: all .18s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
            backdrop-filter: blur(10px);
        }

        .pp:hover {
            background: var(--glass-b);
            box-shadow: var(--sh-sm);
            transform: translateY(-1px)
        }

        .pp.sel.quick {
            border-color: rgba(2, 132, 199, .45);
            background: rgba(2, 132, 199, .07);
            box-shadow: 0 0 0 3px rgba(2, 132, 199, .09)
        }

        .pp.sel.smart {
            border-color: rgba(194, 130, 10, .45);
            background: rgba(194, 130, 10, .07);
            box-shadow: 0 0 0 3px rgba(194, 130, 10, .09)
        }

        /* ══════════ MODE CARDS: QUICK / DEEP ══════════ */
        .mode-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }
