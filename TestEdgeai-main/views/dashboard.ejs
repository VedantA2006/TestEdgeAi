            padding: 24px;
            animation: popIn .2s ease both;
        }
        .confirm-ico {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin: 0 auto 14px;
        }
        .confirm-ico.quick { background: var(--qb); color: var(--qa); }
        .confirm-ico.deep { background: var(--rb); color: var(--ra); }
        .confirm-title { font-size: 17px; font-weight: 800; color: var(--t900); text-align: center; margin-bottom: 6px; letter-spacing: -.3px; }
        .confirm-sub { font-size: 12px; color: var(--t400); text-align: center; margin-bottom: 18px; line-height: 1.6; }
        .confirm-cost {
            background: rgba(194,130,10,.07);
            border: 1px solid rgba(194,130,10,.2);
