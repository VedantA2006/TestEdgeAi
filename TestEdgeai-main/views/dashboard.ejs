        .confirm-cost-val { font-family: var(--fm); font-size: 18px; font-weight: 800; color: var(--sa); }
        .confirm-btns { display: flex; gap: 8px; }
        .confirm-btns .btn-can { flex: 1; }
        .confirm-btns .btn-go { flex: 2; border: none; background: linear-gradient(135deg, var(--navy), #1D4ED8); color: #fff; padding: 10px 20px; border-radius: var(--r-sm); font-size: 13px; font-weight: 700; cursor: pointer; box-shadow: 0 3px 10px rgba(15,36,95,.26); }
        /* Templates modal */
