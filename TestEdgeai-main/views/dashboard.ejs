        function showOptimizeUI(strategyId, plan, status) {
            const optimizeCard = document.getElementById('optimizeCard');
            const compareCard = document.getElementById('compareCard');

            if ((plan === 'deep' || plan === 'research') && status === 'completed') {
                currentParentStrategyId = strategyId;
                optimizeCard.style.display = 'block';
                compareCard.style.display = 'block';
                loadOptimizations(strategyId);
            } else {
                optimizeCard.style.display = 'none';
                compareCard.style.display = 'none';
            }
