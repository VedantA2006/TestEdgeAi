        async function loadOptimizations(parentId) {
            try {
                const res = await fetch(`/api/optimization/parent/${parentId}`);
                
                if (res.status === 401) {
                    window.location.href = '/auth/login';
                    return;
                }

                const data = await res.json();

                if (!data.success) return;

                const content = document.getElementById('compareContent');
                const optRemaining = document.getElementById('optRemaining');

                optRemaining.textContent = `${data.remainingOptimizations} slot${data.remainingOptimizations !== 1 ? 's' : ''} remaining`;

                if (data.optimizations.length === 0) {
                    content.innerHTML = `
                <div style="text-align:center;padding:40px;color:var(--t400)">
                    <i class="fa-solid fa-wand-magic-sparkles" style="font-size:32px;margin-bottom:12px;color:var(--ra)"></i>
                    <p style="margin-bottom:16px">No optimizations yet</p>
                    <p style="font-size:12px">Enter an optimization goal above and click "Start Optimization"</p>
                </div>`;
                    return;
                }

                let html = `<div style="overflow-x:auto"><table style="width:100%;font-size:12px;border-collapse:collapse">
        <thead><tr style="border-bottom:2px solid var(--bdr)">
            <th style="padding:10px;text-align:left">Version</th>
            <th style="padding:10px;text-align:left">Goal</th>
            <th style="padding:10px;text-align:center">Total Return</th>
            <th style="padding:10px;text-align:center">Sharpe</th>
            <th style="padding:10px;text-align:center">Drawdown</th>
            <th style="padding:10px;text-align:center">Status</th>
            <th style="padding:10px;text-align:center">Actions</th>
        </tr></thead><tbody>`;

                const orig = data.parent;
                html += `
        <tr style="background:rgba(2,132,199,.04)">
            <td style="padding:10px;font-weight:700;color:var(--qa)">Original</td>
            <td style="padding:10px;color:var(--t500)">—</td>
            <td style="padding:10px;text-align:center;font-family:var(--fm);font-weight:600;color:${parseFloat(orig.metrics?.['Total Return (%)']) >= 0 ? 'var(--ok)' : 'var(--er)'}">${orig.metrics?.['Total Return (%)'] || '--'}</td>
            <td style="padding:10px;text-align:center;font-family:var(--fm)">${orig.metrics?.['Sharpe Ratio'] || '--'}</td>
            <td style="padding:10px;text-align:center;font-family:var(--fm);color:var(--er)">${orig.metrics?.['Max Drawdown (%)'] || '--'}</td>
            <td style="padding:10px;text-align:center"><span class="sbdg sbdg-s">Completed</span></td>
            <td style="padding:10px;text-align:center"><button class="btn" onclick="viewOptimization('${orig._id}', true)" style="padding:4px 8px;font-size:10px">View</button></td>
        </tr>`;

                data.optimizations.forEach(opt => {
                    const isDone = opt.status === 'completed';
                    const optReturn = parseFloat(opt.metrics?.['Total Return (%)']) || 0;
                    const origReturn = parseFloat(orig.metrics?.['Total Return (%)']) || 0;
                    const optDrawdown = parseFloat(opt.metrics?.['Max Drawdown (%)']) || 0;
                    const origDrawdown = parseFloat(orig.metrics?.['Max Drawdown (%)']) || 0;
                    const optSharpe = parseFloat(opt.metrics?.['Sharpe Ratio']) || 0;
                    const origSharpe = parseFloat(orig.metrics?.['Sharpe Ratio']) || 0;
                    
                    // Check if optimization made things worse
                    const isWorse = isDone && (
                        (optReturn < origReturn - 5) || 
                        (optDrawdown > origDrawdown + 5) || 
                        (optSharpe < origSharpe - 0.3)
                    );
                    
                    // Check if optimization improved
                    const isImproved = isDone && (
                        (optReturn > origReturn + 2) || 
                        (optDrawdown < origDrawdown - 2) || 
                        (optSharpe > origSharpe + 0.2)
                    );
                    
                    const rowStyle = isWorse ? 'background:rgba(220,38,38,.05);border-left:3px solid var(--er)' : 
                                     isImproved ? 'background:rgba(5,150,105,.05);border-left:3px solid var(--ok)' : '';
                    
                    html += `
            <tr style="border-bottom:1px solid var(--bdr);${rowStyle}">
                <td style="padding:10px;font-weight:700;color:var(--ra)">
                    Opt #${opt.optimizationNumber}
                    ${isWorse ? '<i class="fa-solid fa-arrow-trend-down" style="color:var(--er);margin-left:4px" title="Performance worse than original"></i>' : ''}
                    ${isImproved ? '<i class="fa-solid fa-arrow-trend-up" style="color:var(--ok);margin-left:4px" title="Performance improved"></i>' : ''}
                </td>
                <td style="padding:10px;color:var(--t500)">${opt.optimizationGoal || '—'}</td>
                <td style="padding:10px;text-align:center;font-family:var(--fm);font-weight:600;color:${isDone && parseFloat(opt.metrics?.['Total Return (%)']) >= 0 ? 'var(--ok)' : 'var(--er)'}">${isDone ? (opt.metrics?.['Total Return (%)'] || '--') : '<i class="fa-solid fa-spinner fa-spin"></i>'}</td>
                <td style="padding:10px;text-align:center;font-family:var(--fm)">${isDone ? (opt.metrics?.['Sharpe Ratio'] || '--') : '—'}</td>
                <td style="padding:10px;text-align:center;font-family:var(--fm);color:var(--er)">${isDone ? (opt.metrics?.['Max Drawdown (%)'] || '--') : '—'}</td>
                <td style="padding:10px;text-align:center">${isDone ? '<span class="sbdg sbdg-s">Done</span>' : '<span class="sbdg sbdg-r">Running</span>'}</td>
                <td style="padding:10px;text-align:center">${isDone ? `<button class="btn" onclick="viewOptimization('${opt._id}', false)" style="padding:4px 8px;font-size:10px">View</button>` : '—'}</td>
            </tr>`;
                });

                html += `</tbody></table></div>`;

                if (data.canOptimize) {
                    html += `<div style="margin-top:16px;padding:12px;background:rgba(124,58,237,.06);border:1px solid rgba(124,58,237,.2);border-radius:8px;font-size:12px;color:var(--t600)"><i class="fa-solid fa-circle-info"></i> You can run ${data.remainingOptimizations} more optimization${data.remainingOptimizations !== 1 ? 's' : ''} on this strategy.</div>`;
                } else if (data.remainingOptimizations === 0) {
                    html += `<div style="margin-top:16px;padding:12px;background:var(--erb);border:1px solid var(--erbd);border-radius:8px;font-size:12px;color:var(--er)"><i class="fa-solid fa-circle-exclamation"></i> Maximum optimizations reached for this strategy.</div>`;
                }

                content.innerHTML = html;

            } catch (err) {
                console.error('Error loading optimizations:', err);
            }
        }

        async function startOptimization() {
            const goal = document.getElementById('optGoalInput').value.trim();
            const prompt = document.getElementById('optPromptInput').value.trim();
            const status = document.getElementById('optStatus');
            const btn = document.getElementById('btnStartOpt');

            if (!goal) return showToast('Please enter an optimization goal');
            if (!currentParentStrategyId) return showToast('No strategy selected for optimization');

            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Starting...';
            status.style.display = 'block';
            status.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Generating optimized code with AI...';

            try {
                const res = await fetch('/api/optimization/start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        parentStrategyId: currentParentStrategyId,
                        optimizationPrompt: prompt || `Optimize for: ${goal}`,
                        optimizationGoal: goal
                    })
                });

                if (res.status === 401) {
                    window.location.href = '/auth/login';
                    return;
                }

                const data = await res.json();
                if (!res.ok || !data.success) throw new Error(data.error || 'Failed to start optimization');

                showToast(`✓ Optimization #${data.optimizationNumber} started!`);
                document.getElementById('optGoalInput').value = '';
                document.getElementById('optPromptInput').value = '';

                // Polling loop or SSE hook needed here to check status
                // Refreshing view after standard API delay:
                setTimeout(() => {
                    loadOptimizations(currentParentStrategyId);
                    btn.disabled = false;
                    btn.innerHTML = `<i class="fa-solid fa-wand-magic-sparkles"></i> Start Optimization (+<span id="optCost">3</span> credits)`;
                    status.style.display = 'none';
                    
                    var pollTimer = setInterval(async function() {
                        if (!currentParentStrategyId) { clearInterval(pollTimer); return; }
                        const res = await fetch(`/api/optimization/parent/${currentParentStrategyId}`);
                        const d = await res.json();
                        if(d.success) {
                            loadOptimizations(currentParentStrategyId);
                            const isRunning = d.optimizations.some(o => o.status === 'running' || o.status === 'pending');
                            if(!isRunning) clearInterval(pollTimer);
                        }
                    }, 5000);
                }, 3000);

            } catch (err) {
                console.error('Optimization error:', err);
                showToast(err.message || 'Failed to start optimization', 'er');
                btn.disabled = false;
                btn.innerHTML = `<i class="fa-solid fa-wand-magic-sparkles"></i> Start Optimization (+<span id="optCost">3</span> credits)`;
                status.style.display = 'none';
            }
        }

        function viewOptimization(strategyId, isOriginal) {
            window.location.href = `/history/${strategyId}?optimization=${!isOriginal}`;
        }

        /* ══════════════════════════════════════════════
        API: RUN BACKTEST
        ══════════════════════════════════════════════ */
        function rstBtn() {
            var b = document.getElementById('runBtn');
            b.disabled = false;
            b.innerHTML = '<i class="fa-solid fa-bolt"></i>Run Backtest';
        }

        // runBT shows confirmation dialog; doRunBT executes the actual backtest
        function runBT() {
            if (document.getElementById('writeOverlay').classList.contains('open')) {
                stratText = document.getElementById('wrTA').value;
                closeWriter();
            }
            var pl = PLANS[curPlan];
            var validA = assets.filter(function (a) { return a.trim(); });
            var w = wc(stratText);

            if (!validA.length) { showToast('Enter at least one asset symbol before running.'); return; }

            var total = getTotalCost();
            if (credits < total) { showToast('Need ' + total + ' credits for ' + pl.name + '. You have ' + credits + '.'); openBuy(); return; }

            // Build confirm dialog
            var ico = document.getElementById('confirmIco');
            if (ico) {
                ico.className = 'confirm-ico ' + curPlan;
                var mIco = document.getElementById('confirmModeIco');
                if (mIco) mIco.className = 'fa-solid ' + (curPlan === 'quick' ? 'fa-bolt' : 'fa-brain');
            }
            var t = document.getElementById('confirmTitle'); if(t) t.textContent = 'Launch ' + pl.name + '?';
            var hasAsync = curPlan === 'deep' && (deepFeatures.walkForward || deepFeatures.monteCarlo);
            var sub = document.getElementById('confirmSub'); if(sub) sub.textContent = 'Est. ' + pl.eta + ' · ' + pl.model + (hasAsync ? ' · Async job' : '');
            var cv = document.getElementById('confirmCostVal'); if(cv) cv.textContent = total + ' credit' + (total !== 1 ? 's' : '');
            var cb = document.getElementById('confirmBalance'); if(cb) cb.textContent = 'You have ' + credits + ' credits. Remaining after: ' + (credits - total);
            document.getElementById('confirmModal').classList.add('open');
        }

        async function doRunBT() {
            console.log('🚀 doRunBT() called');

            pdata = { yearly: [], monthly: [], metrics: {} };
            lastCode = '';
            document.getElementById('eqImg').src = '';
            document.getElementById('eqCard').style.display = 'none';
            document.getElementById('retGrid').style.display = 'none';
            document.getElementById('codeCard').style.display = 'none';

            var pl = PLANS[curPlan];
            var validA = assets.filter(function (a) { return a.trim(); });
            var w = wc(stratText);
            var prompt = buildPrompt();
            var stratName = document.getElementById('strategyName') ? document.getElementById('strategyName').value : null;

            if (activeES) { activeES.close(); activeES = null; }

            var btn = document.getElementById('runBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="bspin"></span>Running…';
            document.getElementById('emptyW').style.display = 'none';
            document.getElementById('resW').style.display = 'flex';
            document.getElementById('stBdg').style.display = 'none';
            document.getElementById('eqCard').style.display = 'none';
            document.getElementById('retGrid').style.display = 'none';
            document.getElementById('codeCard').style.display = 'none';
            document.getElementById('srow').style.display = 'none';
            document.getElementById('mCont').innerHTML = mkSkel();

            tlog('━━━━━━━━━━━━━━━━━━━━━━━', 'b');
            tlog(curPlan.toUpperCase() + ' Backtest started — ' + pl.name, 'b');
            tlog('Assets: ' + validA.join(', ') + '  |  TF: ' + curTf, 'i');
            if (indicators.length) tlog('Indicators: ' + indicators.join(', '), 'i');
            if (w > 0) tlog('Strategy words: ' + w, 'i');
            var total = getTotalCost();
            tlog('Cost: ' + total + ' credit' + (total > 1 ? 's' : ''), 'w');
            if (curPlan === 'deep') {
                var feats = Object.keys(deepFeatures).filter(function(k) { return deepFeatures[k]; });
                if (feats.length) tlog('Features: ' + feats.join(', '), 'i');
            }
            setProg(5, 'Starting engine…');

            var sid;
            var strategyId;
            try {
                var resp = await fetch('/api/strategy/start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        prompt: prompt,
                        plan: curPlan,
                        timeframe: curTf,
                        assets: validA,
                        indicators: indicators,
                        deepFeatures: deepFeatures,
                        strategyName: stratName
                    })
                });
                var data = await resp.json();
                if (!resp.ok) throw new Error(data.error || 'Server error');
                sid = data.sessionId;
                strategyId = data.strategyId;
                var nc = data.newCredits !== undefined ? data.newCredits : credits - total;
                setCr(nc);
                tlog('Session: ' + sid, 's');
                tlog('Credits remaining: ' + nc, 'w');
                if (data.warning) tlog('⚠ ' + data.warning, 'w');
                if (data.modeLabel) tlog('Mode: ' + data.modeLabel + (data.model ? ' · ' + data.model : ''), 'i');
                if (data.estimatedTime) tlog('Estimated: ' + data.estimatedTime, 'i');
            } catch (err) {
                tlog('✗ ' + err.message, 'e');
                rstBtn(); hideProg();
                return;
            }

            var es = new EventSource('/api/strategy/stream/' + sid);
            activeES = es;
            var typeMap = { info: 'i', success: 's', error: 'e', warn: 'w' };

            es.addEventListener('log', function (e) { var d = JSON.parse(e.data); tlog(d.msg, typeMap[d.type] || 'i'); });
            es.addEventListener('progress', function (e) { var d = JSON.parse(e.data); setProg(d.value, d.label); });
            es.addEventListener('code_status', function (e) { var d = JSON.parse(e.data); setStat(d.state, d.message); });
            es.addEventListener('code', function (e) {
                var d = JSON.parse(e.data);
                lastCode = d.code;
                document.getElementById('codeBox').textContent = d.code;
                document.getElementById('codeBox').classList.remove('err');
                document.getElementById('codeCard').style.display = 'block';
            });

            es.addEventListener('output', function (e) {
                try {
                    var d = JSON.parse(e.data);
                    renderM(d.output);
                    if ((curPlan === 'deep' || curPlan === 'research') && d.output.includes('BACKTEST SUMMARY:')) {
                        showOptimizeUI(strategyId, curPlan, 'completed');
                    }
                } catch (err) {
                    console.error('Error parsing stream output:', err);
                }
            });

            es.addEventListener('chart', function (e) {
                var img = document.getElementById('eqImg');
                img.src = '/temp/equity.png?t=' + Date.now() + '&s=' + sid;
                img.onload = function () { document.getElementById('eqCard').style.display = 'block'; tlog('✓ Equity curve ready', 's'); };
                img.onerror = function () { tlog('⚠ Chart image not found', 'w'); };
            });

            es.addEventListener('done', function (e) {
                var d = JSON.parse(e.data); es.close(); activeES = null; rstBtn();
                if (d.success) {
                    setProg(100, 'Complete — attempt ' + d.attempt);
                    tlog('✓ Backtest complete (attempt ' + d.attempt + ')', 's');
                    setStat('success', 'Completed');
                    setTimeout(hideProg, 3000);
                } else {
                    setStat('error', 'Failed');
                    document.getElementById('codeBox').classList.add('err');
                    if (!lastCode) document.getElementById('codeBox').textContent = d.error || 'Execution failed';
                    tlog('✗ ' + (d.error || 'Failed'), 'e');
                    hideProg();
                }
            });

            es.onerror = function () { tlog('⚠ Stream closed', 'w'); es.close(); activeES = null; rstBtn(); };
        }
    </script>
</body>

</html>
