    <div class="toast" id="toast">
        <i class="fa-solid fa-circle-exclamation tico"></i>
        <div class="tbody_">
            <div class="tttl">Heads up</div>
            <div class="tmsg_" id="tmsg">—</div>
        </div>
        <button class="tcls" id="btnClsToast"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <script>
        /* ══════════════════════════════════════════════
        CONFIG & GLOBALS
        ══════════════════════════════════════════════ */
        var PLANS = {
            quick: {
                name: 'QUICK Backtest', credits: 3, maxWords: 150, maxAssets: 2, maxInds: 3,
                timeframes: ['1d', '1h'],
                history: { '1d': '1 year', '1h': '1 year' },
                cls: 'qt', icon: 'fa-bolt', colorVar: '--qa', planKey: 'quick',
                model: 'Gemini Flash', eta: '~30 sec'
            },
            deep: {
                name: 'DEEP Backtest', credits: 12, maxWords: 1500, maxAssets: 999, maxInds: 999,
                timeframes: ['1m', '5m', '15m', '30m', '1h', '4h', '1d'],
                history: { '1m': '7–15 days', '5m': '90–180 days', '15m': '1–2 years', '30m': '2–3 years', '1h': '5 years', '4h': '8 years', '1d': 'Max available' },
                cls: 'rt', icon: 'fa-brain', colorVar: '--ra', planKey: 'deep',
                model: 'Gemini Pro', eta: '2–5 min'
            }
        };
        var MONTHS = { jan: 0, january: 0, feb: 1, february: 1, mar: 2, march: 2, apr: 3, april: 3, may: 4, jun: 5, june: 5, jul: 6, july: 6, aug: 7, august: 7, sep: 8, september: 8, oct: 9, october: 9, nov: 10, november: 10, dec: 11, december: 11 };

        // Deep features state
        var deepFeatures = { walkForward: false, monteCarlo: false, positionSizing: false, optimization: false };

        // Rendered securely by EJS engine
        var credits = Number('<%= user.creditTokens %>') || 0;
        var curPlan = 'quick';
        var curTf = '1h';
        var stratText = '';
        var indicators = [];
        var assets = [''];
        var selPkAmt = 50;
        var lastCode = '';
        var activeES = null;
        var yrChart = null;
        var pdata = { yearly: [], monthly: [], metrics: {} };
        var toastTimer = null;
        var currentParentStrategyId = null;

        /* ══════════════════════════════════════════════
        INIT
        ══════════════════════════════════════════════ */
        document.addEventListener('DOMContentLoaded', function () {
            // Mode card clicks
            document.getElementById('mq').addEventListener('click', function() { selMode('quick'); });
            document.getElementById('md').addEventListener('click', function() { selMode('deep'); });

            // Wire up UI events
            document.getElementById('crPill').addEventListener('click', openBuy);
            document.getElementById('btnBuyNav').addEventListener('click', function (e) { e.stopPropagation(); openBuy(); });
            document.getElementById('railExpand').addEventListener('click', expandSidebar);
            document.getElementById('railCmp').addEventListener('click', openCmp);
            document.getElementById('railBuy').addEventListener('click', openBuy);
            document.getElementById('cmpLnk').addEventListener('click', openCmp);
            document.getElementById('btnAddAsset').addEventListener('click', addAsset);
            document.getElementById('btnTemplates').addEventListener('click', openTemplates);

            var tagInput = document.getElementById('tagInput');
            tagInput.addEventListener('keydown', tagKeydown);
            tagInput.addEventListener('input', tagOnInput);
            document.getElementById('tagBox').addEventListener('click', function () { tagInput.focus(); });

            document.getElementById('stratBtn').addEventListener('click', openWriter);
            document.getElementById('btnCloseWr').addEventListener('click', closeWriter);
            document.getElementById('btnApply').addEventListener('click', applyWriter);
            document.getElementById('wrTA').addEventListener('input', writerInput);
            document.getElementById('writeOverlay').addEventListener('click', function (e) { if (e.target === this) closeWriter(); });

            document.getElementById('btnCloseBuy').addEventListener('click', closeBuy);
            document.getElementById('btnCancelBuy').addEventListener('click', closeBuy);

            document.getElementById('pk50').addEventListener('click', function () { selPk(50); });
            document.getElementById('pk200').addEventListener('click', function () { selPk(200); });
            document.getElementById('pk500').addEventListener('click', function () { selPk(500); });

            document.getElementById('btnCloseCmp').addEventListener('click', closeCmp);
            document.getElementById('btnCloseCmp2').addEventListener('click', closeCmp);
            document.getElementById('buyModal').addEventListener('click', function (e) { if (e.target === this) closeBuy(); });
            document.getElementById('cmpModal').addEventListener('click', function (e) { if (e.target === this) closeCmp(); });

            document.getElementById('runBtn').addEventListener('click', runBT);
            document.getElementById('runBtnMini').addEventListener('click', runBT);
            document.getElementById('btnClrTerm').addEventListener('click', function () { document.getElementById('terminal').innerHTML = ''; tlog('Terminal cleared', 'i'); });

            document.getElementById('btnDl').addEventListener('click', togDl);
            document.getElementById('dlPy').addEventListener('click', dlCode);
            document.getElementById('dlCsv').addEventListener('click', function () { dlRes('csv'); });
            document.getElementById('dlPdf').addEventListener('click', function () { dlRes('pdf'); });
            document.getElementById('btnDlChart').addEventListener('click', dlChart);

            // Confirm modal
            document.getElementById('btnCancelConfirm').addEventListener('click', function() { document.getElementById('confirmModal').classList.remove('open'); });
            document.getElementById('btnConfirmRun').addEventListener('click', function() {
                document.getElementById('confirmModal').classList.remove('open');
                doRunBT();
            });
            document.getElementById('confirmModal').addEventListener('click', function(e) {
                if (e.target === this) this.classList.remove('open');
            });

            // Templates modal
            document.getElementById('btnCloseTpl').addEventListener('click', closeTpl);
            document.getElementById('btnCloseTpl2').addEventListener('click', closeTpl);
            document.getElementById('tplModal').addEventListener('click', function(e) { if (e.target === this) closeTpl(); });

            // Optimization Event Listeners
            const btnStartOpt = document.getElementById('btnStartOpt');
            if (btnStartOpt) btnStartOpt.addEventListener('click', startOptimization);

            const btnRefresh = document.getElementById('btnRefreshCompare');
            if (btnRefresh) {
                btnRefresh.addEventListener('click', () => {
                    if (currentParentStrategyId) loadOptimizations(currentParentStrategyId);
                });
            }

            document.addEventListener('click', function (e) {
                var dlW = document.getElementById('dlW');
                if (dlW && !dlW.contains(e.target)) document.getElementById('dlm').classList.remove('open');
            });

            document.getElementById('btnClsToast').addEventListener('click', closeToast);
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeWriter(); });

            selMode('quick');
            tlog('🚀 QuantAI Studio ready', 'b');
            tlog('Balance: ' + credits + ' credits', 's');
            tlog('Fill in the fields and press Run.', 'i');
        });

        function selMode(m) {
            var validModes = ['quick','deep'];
            if (!PLANS[m]) m = 'quick';
            ['mq','md'].forEach(function(id) { var el=document.getElementById(id); if(el) el.classList.remove('sel'); });
            var elId = m === 'quick' ? 'mq' : 'md';
            var el = document.getElementById(elId); if(el) el.classList.add('sel');
            curPlan = m;
            var pl = PLANS[m];

            // Show/hide QUICK constraints vs DEEP feature toggles
            var qc = document.getElementById('quickConstraints');
            var df = document.getElementById('deepFeats');
            var sn = document.getElementById('snameWrap');
            if (m === 'quick') {
                if(qc) qc.style.display = 'flex';
                if(df) df.style.display = 'none';
                if(sn) sn.style.display = 'none';
            } else {
                if(qc) qc.style.display = 'none';
                if(df) df.style.display = 'flex';
                if(sn) sn.style.display = 'flex';
            }

            document.getElementById('assetLimit').textContent = pl.maxAssets >= 999 ? 'Unlimited' : 'Max ' + pl.maxAssets;
            document.getElementById('indLimit').textContent = pl.maxInds >= 999 ? 'Unlimited' : 'Max ' + pl.maxInds;
            var assetCap = pl.maxAssets >= 999 ? 99 : pl.maxAssets;
            assets = assets.slice(0, assetCap);
            rebuildAssets();
            rebuildTF();
            if (pl.maxInds < 999 && indicators.length > pl.maxInds) { indicators = indicators.slice(0, pl.maxInds); rebuildTags(); }

            updCostDisplay();
            document.getElementById('railPlanIcon').className = 'fa-solid ' + pl.icon;
            updWC();
            updWrMeta();
        }
        // Legacy alias for stray calls
        function selPlan(p) { selMode(p === 'research' ? 'deep' : p === 'smart' ? 'deep' : p); }

        function getTotalCost() {
            var base = PLANS[curPlan].credits;
            if (curPlan === 'deep' && deepFeatures.optimization) base += 3;
            return base;
        }
        function updCostDisplay() {
            var pl = PLANS[curPlan];
            var total = getTotalCost();
            document.getElementById('costT').textContent = pl.name;
            if (document.getElementById('costEta')) document.getElementById('costEta').textContent = pl.eta + ' \u00b7 ' + pl.model;
            if (document.getElementById('costNum')) document.getElementById('costNum').textContent = total;
        }
        function toggleFeat(feat) {
            if (curPlan !== 'deep') return;
            deepFeatures[feat] = !deepFeatures[feat];
            var togId = { walkForward: 'togWF', monteCarlo: 'togMC', positionSizing: 'togPS', optimization: 'togOpt' }[feat];
            if (togId) { var t = document.getElementById(togId); if(t) t.classList.toggle('on', deepFeatures[feat]); }
            var hasAsync = deepFeatures.walkForward || deepFeatures.monteCarlo;
            if (document.getElementById('mdEta')) document.getElementById('mdEta').textContent = hasAsync ? '5\u201315 min' : '2\u20135 min';
            PLANS.deep.eta = hasAsync ? '5\u201315 min' : '2\u20135 min';
            updCostDisplay();
        }

        // Templates
        var _templates = null;
        function openTemplates() {
            document.getElementById('tplModal').classList.add('open');
            if (_templates) return;
            fetch('/api/strategy/templates').then(function(r) { return r.json(); }).then(function(d) {
                _templates = d.templates;
                renderTemplates();
            }).catch(function() {
                document.getElementById('tplGrid').innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:20px;color:var(--er)">Failed to load templates</div>';
            });
        }
        function closeTpl() { document.getElementById('tplModal').classList.remove('open'); }
        function renderTemplates() {
            if (!_templates) return;
            var h = '';
            _templates.forEach(function(t) {
                var tEnc = encodeURIComponent(JSON.stringify(t));
                h += '<div class="tpl-card" onclick="applyTemplate(decodeURIComponent(\'' + tEnc + '\'))">';
                h += '<div class="tpl-ico"><i class="fa-solid ' + t.icon + '"></i></div>';
                h += '<div class="tpl-name">' + escH(t.name) + '</div>';
                h += '<div class="tpl-desc">' + escH(t.description) + '</div>';
                h += '</div>';
            });
            document.getElementById('tplGrid').innerHTML = h;
        }
        function applyTemplate(tStr) {
            var t = typeof tStr === 'string' ? JSON.parse(tStr) : tStr;
            indicators = [];
            if (t.indicators) t.indicators.forEach(function(ind) { addTag(ind); });
            if (t.suggestedAssets && t.suggestedAssets.length) {
                assets = [t.suggestedAssets[0]];
                rebuildAssets();
            }
            stratText = t.prompt;
            if (document.getElementById('wrTA')) document.getElementById('wrTA').value = stratText;
            updWC();
            updWrMeta();
            var tw = document.getElementById('tfWrap');
            if (tw && t.suggestedTimeframe) {
                var btns = tw.querySelectorAll('.tfc');
                btns.forEach(function(btn) {
                    if (btn.textContent === t.suggestedTimeframe) selTf(t.suggestedTimeframe, btn);
                });
            }
            closeTpl();
            tlog('\u2713 Template applied: ' + t.name, 's');
        }

        function rebuildTF() {
            var pl = PLANS[curPlan];
            var wrap = document.getElementById('tfWrap');
            wrap.innerHTML = '';
            pl.timeframes.forEach(function (tf) {
                var c = document.createElement('button');
                c.className = 'tfc';
                c.textContent = tf;
                c.type = 'button';
                c.addEventListener('click', function () { selTf(tf, this); });
                wrap.appendChild(c);
            });
            var defTf = pl.timeframes.indexOf('1h') !== -1 ? '1h' : pl.timeframes[0];
            var defChip = wrap.querySelector('.tfc');
            pl.timeframes.forEach(function (tf, i) {
                if (tf === defTf) defChip = wrap.children[i];
            });
            selTf(defTf, defChip);
        }
        function selTf(tf, chip) {
            document.getElementById('tfWrap').querySelectorAll('.tfc').forEach(function (c) {
                c.classList.remove('act', 'qt', 'st', 'rt');
            });
            chip.classList.add('act', PLANS[curPlan].cls);
            curTf = tf;
            var h = PLANS[curPlan].history[tf];
            document.getElementById('histVal').textContent = h || '—';
            document.getElementById('histNote').textContent = h ? 'for ' + tf + ' candles' : 'No history info';
            updWrMeta();
        }

        function rebuildAssets() {
            var pl = PLANS[curPlan];
            var list = document.getElementById('assetList');
