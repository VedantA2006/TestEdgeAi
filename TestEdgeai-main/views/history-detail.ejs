<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Strategy Details - QuantAI Studio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <style>
    /* ══════════ TOKENS ══════════ */
    :root{
      --bg:#EEF2F7;--glass-a:rgba(255,255,255,.55);--glass-b:rgba(255,255,255,.75);
      --glass-c:rgba(255,255,255,.88);--glass-nav:rgba(255,255,255,.80);
      --bdr:rgba(255,255,255,.85);--bdr2:rgba(255,255,255,.95);
      --blur:blur(24px) saturate(180%);
      --sh-sm:0 2px 12px rgba(15,23,42,.07),inset 0 1px 0 rgba(255,255,255,.85);
      --sh-md:0 6px 24px rgba(15,23,42,.09),inset 0 1px 0 rgba(255,255,255,.9);
      --sh-lg:0 16px 48px rgba(15,23,42,.12),inset 0 1px 0 rgba(255,255,255,.95);
      --navy:#0F2444;--qa:#0284C7;--qb:rgba(2,132,199,.09);--qbd:rgba(2,132,199,.3);--qt:#025C8F;
      --sa:#C2820A;--sb:rgba(194,130,10,.09);--sbd:rgba(194,130,10,.3);--st:#7A520A;
      --ra:#7C3AED;--rb:rgba(124,58,237,.09);--rbd:rgba(124,58,237,.3);--rt:#5B21B6;
      --ok:#059669;--okb:rgba(5,150,105,.1);--okbd:rgba(5,150,105,.3);
      --er:#DC2626;--erb:rgba(220,38,38,.1);--erbd:rgba(220,38,38,.3);
      --wn:#D97706;--wnb:rgba(217,119,6,.1);
      --t900:#060F1F;--t800:#1A2942;--t700:#334155;--t600:#475569;
      --t500:#64748B;--t400:#94A3B8;--t300:#CBD5E1;--t200:#E2E8F0;
      --r-xs:6px;--r-sm:8px;--r-md:12px;--r-lg:16px;--r-xl:20px;--r-2xl:26px;
      --fs:'DM Sans',system-ui,sans-serif;--fm:'JetBrains Mono',monospace;
    }
    /* ══════════ RESET ══════════ */
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--fs);background:var(--bg);color:var(--t700);min-height:100vh}
    a{text-decoration:none;color:inherit}
    button{font-family:var(--fs)}
    ::-webkit-scrollbar{width:4px;height:4px}
    ::-webkit-scrollbar-track{background:transparent}
    ::-webkit-scrollbar-thumb{background:rgba(100,116,139,.25);border-radius:4px}
    /* ══════════ BACKGROUND ══════════ */
    #bgMesh{
      position:fixed;inset:0;z-index:0;pointer-events:none;
      background:
        radial-gradient(ellipse 70% 55% at 10% 35%, rgba(2,132,199,.13) 0%,transparent 60%),
        radial-gradient(ellipse 55% 50% at 88% 18%, rgba(124,58,237,.09) 0%,transparent 55%),
        radial-gradient(ellipse 45% 65% at 65% 92%, rgba(15,36,68,.07) 0%,transparent 55%),
        linear-gradient(145deg,#EBF4FF 0%,#F5F7FA 45%,#EEF0F5 100%);
    }
    /* ══════════ ANIMATIONS ══════════ */
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    @keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
    /* ══════════ NAVBAR ══════════ */
    .nav{
      height:58px;background:var(--glass-nav);
      backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);
      border-bottom:1px solid var(--bdr);
      box-shadow:0 2px 10px rgba(15,23,42,.06);
      display:flex;align-items:center;justify-content:space-between;
      padding:0 22px;position:relative;z-index:100;
    }
    .nav-left{display:flex;align-items:center;gap:14px}
    .btn-back{
      display:flex;align-items:center;gap:6px;
      background:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.82);
      color:var(--t500);padding:6px 12px;border-radius:var(--r-sm);
      font-size:12px;font-weight:600;cursor:pointer;transition:all .14s;
    }
    .btn-back:hover{background:var(--glass-b);color:var(--t700)}
    .brand{display:flex;align-items:center;gap:10px;font-size:16px;font-weight:800;color:var(--navy)}
    .nav-right{display:flex;align-items:center;gap:8px}
    .btn-dl-all{
      background:linear-gradient(135deg,var(--navy),#1D4ED8);border:none;color:#fff;
      padding:7px 14px;border-radius:var(--r-sm);font-size:12px;font-weight:700;
      cursor:pointer;transition:all .14s;display:flex;align-items:center;gap:6px;
      box-shadow:0 3px 10px rgba(15,36,95,.22);
    }
    .btn-dl-all:hover{transform:translateY(-1px);box-shadow:0 5px 14px rgba(15,36,95,.32)}
    /* ══════════ MAIN ══════════ */
    .main{max-width:1400px;margin:0 auto;padding:22px;display:flex;flex-direction:column;gap:16px;animation:fadeUp .4s ease both}
    /* ══════════ GLASS CARDS ══════════ */
    .gc{
      background:var(--glass-b);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);
      border:1px solid var(--bdr);border-radius:var(--r-xl);
      box-shadow:var(--sh-sm);overflow:hidden;animation:fadeUp .35s ease both;
    }
    .gc-hd{
      padding:13px 18px;display:flex;align-items:center;justify-content:space-between;
      background:rgba(255,255,255,.3);border-bottom:1px solid rgba(255,255,255,.5);
    }
    .gc-tit{display:flex;align-items:center;gap:9px;font-size:14px;font-weight:700;color:var(--t900)}
    .gc-body{padding:18px}
    .gc-acts{display:flex;gap:6px}
    /* ══════════ STRATEGY HEADER ══════════ */
    .strategy-header{
      display:flex;align-items:center;justify-content:space-between;
      padding:20px 24px;background:linear-gradient(135deg,rgba(2,132,199,.08),rgba(124,58,237,.06));
      border-bottom:1px solid rgba(255,255,255,.5);
    }
    .sh-left{display:flex;align-items:center;gap:16px}
    .sh-ico{
      width:52px;height:52px;border-radius:14px;
      display:flex;align-items:center;justify-content:center;
      font-size:20px;background:var(--glass-b);border:1px solid var(--bdr);
      box-shadow:var(--sh-sm);
    }
    .sh-ico.q{background:var(--qb);color:var(--qa)}
    .sh-ico.s{background:var(--sb);color:var(--sa)}
    .sh-ico.r{background:var(--rb);color:var(--ra)}
    .sh-info{}
    .sh-title{font-size:18px;font-weight:800;color:var(--t900);margin-bottom:4px}
    .sh-meta{display:flex;flex-wrap:wrap;gap:8px;font-size:11px;color:var(--t400)}
    .sh-chip{
      display:inline-flex;align-items:center;gap:4px;
      background:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.82);
      border-radius:8px;padding:4px 9px;font-weight:600;font-family:var(--fm);
    }
    .sbdg{
      display:inline-flex;align-items:center;gap:5px;
      font-size:9px;font-weight:700;padding:3px 8px;border-radius:12px;
      text-transform:uppercase;font-family:var(--fm);
    }
    .sbdg-s{background:var(--okb);color:var(--ok);border:1px solid var(--okbd)}
    .sbdg-e{background:var(--erb);color:var(--er);border:1px solid var(--erbd)}
    /* ══════════ STATS GRID ══════════ */
    .stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
    .stat-c{
      background:var(--glass-b);backdrop-filter:var(--blur);
      border:1px solid var(--bdr);border-radius:var(--r-lg);
      padding:16px;text-align:center;box-shadow:var(--sh-sm);transition:all .18s;
    }
    .stat-c:hover{transform:translateY(-2px);box-shadow:var(--sh-md)}
    .sv{font-size:26px;font-weight:800;color:var(--navy);margin-bottom:3px;letter-spacing:-1px}
    .sv.pos{color:var(--ok)}.sv.neg{color:var(--er)}
    .slb{font-size:9.5px;color:var(--t400);text-transform:uppercase;letter-spacing:.8px;font-weight:700}
    /* ══════════ METRICS LIST ══════════ */
    .ml{display:flex;flex-direction:column}
    .mr{
      display:flex;align-items:center;justify-content:space-between;
      padding:9px 0;border-bottom:1px solid rgba(100,116,139,.07);
      animation:fadeIn .28s ease both;
    }
    .mr:last-child{border-bottom:none}
    .mk{font-size:12.5px;color:var(--t500);display:flex;align-items:center;gap:7px}
    .mk i{font-size:11px;color:var(--t300);width:13px;text-align:center}
    .mv{font-family:var(--fm);font-size:12.5px;font-weight:600;color:var(--t900)}
    .mv.pos{color:var(--ok)}.mv.neg{color:var(--er)}
    /* ══════════ CODE ══════════ */
    .cpre{
      background:#0D1117;padding:16px;font-family:var(--fm);
      font-size:11.5px;line-height:1.75;color:#8B949E;
      white-space:pre;overflow:auto;min-height:100px;max-height:500px;
    }
    /* ══════════ CHART ══════════ */
    .cwrap{position:relative;height:280px}
    .cimg{width:100%;height:auto;border-radius:var(--r-sm);display:block;border:1px solid rgba(255,255,255,.55)}
    /* ══════════ HEATMAP ══════════ */
    .hmg{display:grid;grid-template-columns:40px repeat(12,1fr);gap:3px;padding:12px}
    .hmmh{font-size:8px;font-weight:700;color:var(--t400);text-align:center;padding:3px 0;font-family:var(--fm)}
    .hmyr{font-family:var(--fm);font-size:9px;font-weight:600;color:var(--t500);display:flex;align-items:center;justify-content:flex-end;padding-right:4px}
    .hmcell{
      aspect-ratio:1;border-radius:3px;display:flex;align-items:center;justify-content:center;
      font-weight:700;font-family:var(--fm);font-size:8.5px;cursor:pointer;transition:all .11s;
    }
    .hmcell:hover{transform:scale(1.2);z-index:2;box-shadow:0 2px 8px rgba(0,0,0,.14)}
    .hmcell.pos{color:#fff}.hmcell.neg{color:#fff}.hmcell.nil{background:rgba(100,116,139,.1);color:var(--t300)}
    .hmleg{display:flex;align-items:center;gap:7px;padding:7px 12px;font-size:9px;color:var(--t400);border-top:1px solid rgba(255,255,255,.45);font-family:var(--fm)}
    .hmgr{display:flex;gap:2px;flex:1;max-width:150px}.hmgr span{flex:1;height:7px;border-radius:2px}
    /* ══════════ BUTTONS ══════════ */
    .btn{
      display:inline-flex;align-items:center;gap:6px;
      background:rgba(255,255,255,.55);border:1px solid rgba(255,255,255,.82);
      color:var(--t500);padding:6px 12px;border-radius:var(--r-sm);
      font-size:12px;font-weight:600;cursor:pointer;transition:all .14s;
    }
    .btn:hover{background:var(--glass-b);color:var(--t700);transform:translateY(-1px);box-shadow:var(--sh-sm)}
    .btn-prim{
      background:linear-gradient(135deg,var(--navy),#1D4ED8);border-color:transparent;color:#fff;
      box-shadow:0 3px 10px rgba(15,36,95,.22);
    }
    .btn-prim:hover{color:#fff;box-shadow:0 5px 14px rgba(15,36,95,.32)}
    .btn-danger{background:rgba(220,38,38,.08);color:var(--er);border-color:rgba(220,38,38,.2)}
    .btn-danger:hover{background:rgba(220,38,38,.15)}
    /* ══════════ LOADING ══════════ */
    .loading{
      display:flex;flex-direction:column;align-items:center;justify-content:center;
      min-height:400px;gap:14px;
    }
    .spinner{
      width:40px;height:40px;border:3px solid rgba(59,130,246,.2);
      border-right-color:#3B82F6;border-radius:50%;animation:spin .6s linear infinite;
    }
    @keyframes spin{to{transform:rotate(360deg)}}
    /* ══════════ RESPONSIVE ══════════ */
    @media(max-width:1160px){.stat-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:900px){.strategy-header{flex-direction:column;align-items:flex-start;gap:12px}}
    @media(max-width:580px){.stat-grid{grid-template-columns:1fr 1fr;gap:8px}.sv{font-size:22px}}
  </style>
</head>
<body>
  <div id="bgMesh"></div>
  
  <!-- NAVBAR -->
  <nav class="nav">
    <div class="nav-left">
      <button class="btn-back" onclick="window.location.href='/history'">
        <i class="fa-solid fa-arrow-left"></i>Back
      </button>
      <div class="brand">
        <i class="fa-solid fa-chart-candlestick"></i>
        QuantAI Studio
      </div>
    </div>
    <div class="nav-right">
      <button class="btn-dl-all" onclick="downloadAll()">
        <i class="fa-solid fa-download"></i>Download All
      </button>
    </div>
  </nav>

  <!-- MAIN CONTENT -->
  <main class="main" id="mainContent">
    <div class="loading">
      <div class="spinner"></div>
      <div style="font-size:14px;color:var(--t500)">Loading strategy details...</div>
    </div>
  </main>

  <script>
    var strategyData = null;
    var yrChart = null;

    // Load strategy data
    async function loadStrategy() {
      const pathParts = window.location.pathname.split('/');
      const strategyId = pathParts[pathParts.length - 1];
      
      try {
        const res = await fetch('/api/history/' + strategyId);
        const data = await res.json();
        
        if (!data.success) {
          alert('Strategy not found');
          window.location.href = '/history';
          return;
        }
        
        strategyData = data.strategy;
        renderPage();
      } catch (err) {
        console.error('Error loading strategy:', err);
        alert('Failed to load strategy');
      }
    }

    function renderPage() {
      const s = strategyData;
      const planClass = s.plan === 'quick' ? 'q' : s.plan === 'smart' ? 's' : 'r';
      const planIcon = s.plan === 'quick' ? 'fa-binoculars' : s.plan === 'smart' ? 'fa-chart-line' : 'fa-flask';
      const statusClass = s.status === 'completed' ? 's' : 'e';
      
      document.getElementById('mainContent').innerHTML = `
        <!-- Strategy Header -->
        <div class="gc">
          <div class="strategy-header">
            <div class="sh-left">
              <div class="sh-ico ${planClass}">
                <i class="fa-solid ${planIcon}"></i>
              </div>
              <div class="sh-info">
                <div class="sh-title">${s.assets.join(', ')}</div>
                <div class="sh-meta">
                  <span class="sh-chip"><i class="fa-solid fa-clock"></i>${s.timeframe}</span>
                  <span class="sh-chip"><i class="fa-solid fa-coins"></i>${s.creditsUsed} credits</span>
                  <span class="sh-chip"><i class="fa-solid fa-calendar"></i>${new Date(s.createdAt).toLocaleDateString()}</span>
                  <span class="sbdg sbdg-${statusClass}">${s.status}</span>
                </div>
              </div>
            </div>
            <div class="gc-acts">
              <button class="btn" onclick="downloadCode()"><i class="fa-brands fa-python"></i>Code</button>
              <button class="btn" onclick="downloadChart()"><i class="fa-solid fa-image"></i>Chart</button>
              <button class="btn btn-prim" onclick="downloadJSON()"><i class="fa-solid fa-file"></i>Full Data</button>
            </div>
          </div>
          <div class="gc-body">
            <div class="stat-grid">
              <div class="stat-c">
                <div class="sv ${parseFloat(s.metrics?.totalReturn || 0) >= 0 ? 'pos' : 'neg'}">${s.metrics?.totalReturn || '--'}%</div>
                <div class="slb">Total Return</div>
              </div>
              <div class="stat-c">
                <div class="sv ${parseFloat(s.metrics?.cagr || 0) >= 0 ? 'pos' : 'neg'}">${s.metrics?.cagr || '--'}%</div>
                <div class="slb">CAGR</div>
              </div>
              <div class="stat-c">
                <div class="sv neg">${s.metrics?.maxDrawdown || '--'}%</div>
                <div class="slb">Max Drawdown</div>
              </div>
              <div class="stat-c">
                <div class="sv">${s.metrics?.totalTrades || '--'}</div>
                <div class="slb">Total Trades</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Metrics & Equity Curve -->
        <div class="r2" style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div class="gc">
            <div class="gc-hd">
              <div class="gc-tit"><i class="fa-solid fa-chart-pie"></i>Performance Metrics</div>
            </div>
            <div class="gc-body">
              <div class="ml" id="metricsList"></div>
            </div>
          </div>
          <div class="gc" id="eqCard">
            <div class="gc-hd">
              <div class="gc-tit"><i class="fa-solid fa-chart-area"></i>Equity Curve</div>
              <button class="btn" onclick="downloadChart()"><i class="fa-solid fa-download"></i>Save</button>
            </div>
            <div class="gc-body" style="padding:12px">
              <div class="cwrap">
                <img id="eqImg" class="cimg" src="/temp/equity.png?t=${Date.now()}" alt="Equity Curve">
              </div>
            </div>
          </div>
        </div>

        <!-- Yearly & Monthly Returns -->
        <div class="r2" style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div class="gc">
            <div class="gc-hd">
              <div class="gc-tit"><i class="fa-solid fa-chart-column"></i>Yearly Returns</div>
            </div>
            <div class="gc-body" style="padding:10px">
              <canvas id="yrChart" style="max-height:260px"></canvas>
            </div>
          </div>
          <div class="gc">
            <div class="gc-hd">
              <div class="gc-tit"><i class="fa-solid fa-table-cells"></i>Monthly Heatmap</div>
            </div>
            <div class="gc-body" style="padding:0">
              <div id="hmCont"></div>
              <div class="hmleg">
                <span>Loss</span>
                <div class="hmgr">
                  <span style="background:#DC2626"></span>
                  <span style="background:#F87171"></span>
                  <span style="background:#FCA5A5"></span>
                  <span style="background:#E2E8F0"></span>
                  <span style="background:#86EFAC"></span>
                  <span style="background:#22C55E"></span>
                  <span style="background:#15803D"></span>
                </div>
                <span>Gain</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Strategy Code -->
        <div class="gc" id="codeCard">
          <div class="gc-hd">
            <div class="gc-tit"><i class="fa-brands fa-python"></i>AI-Generated Strategy Code</div>
            <div class="gc-acts">
              <button class="btn btn-prim" onclick="downloadCode()"><i class="fa-solid fa-download"></i>Download .py</button>
            </div>
          </div>
          <div class="gc-body" style="padding:0">
            <pre class="cpre" id="codeBox">${escapeHtml(s.generatedCode || 'Code not available')}</pre>
          </div>
        </div>

        <!-- Strategy Logic -->
        <div class="gc">
          <div class="gc-hd">
            <div class="gc-tit"><i class="fa-solid fa-pen-to-square"></i>Strategy Logic</div>
          </div>
          <div class="gc-body">
            <div style="font-size:13px;line-height:1.7;color:var(--t700);white-space:pre-wrap">${escapeHtml(s.strategyLogic || 'No strategy logic provided')}</div>
          </div>
        </div>
      `;

      // Render metrics list
      renderMetrics(s.metrics);
      
      // Render yearly chart
      if (s.yearlyReturns && s.yearlyReturns.length > 0) {
        renderYearlyChart(s.yearlyReturns);
      }
      
      // Render monthly heatmap
      if (s.monthlyReturns && s.monthlyReturns.length > 0) {
        renderHeatmap(s.monthlyReturns);
      }
    }

    function renderMetrics(metrics) {
      const IMAP = {
        'Start Date':'fa-calendar-plus','End Date':'fa-calendar-check','Timeframe':'fa-clock',
        'Total Return (%)':'fa-percent','CAGR (%)':'fa-arrow-trend-up','Max Drawdown (%)':'fa-arrow-trend-down',
        'Win Rate (%)':'fa-bullseye','Profit Factor':'fa-scale-balanced','Sharpe Ratio':'fa-chart-line',
        'Total Trades':'fa-repeat'
      };
      
      const list = document.getElementById('metricsList');
      if (!list || !metrics) return;
      
      let html = '';
      for (const [key, value] of Object.entries(metrics)) {
        if (!value) continue;
        const ico = IMAP[key] || 'fa-circle-dot';
        let vc = '';
        if (key.indexOf('Return') !== -1 || key.indexOf('CAGR') !== -1) {
          const n = parseFloat(value);
          if (!isNaN(n)) vc = n >= 0 ? ' pos' : ' neg';
        }
        if (key.indexOf('Drawdown') !== -1) vc = ' neg';
        
        html += `
          <div class="mr">
            <span class="mk"><i class="fa-solid ${ico}"></i>${escapeHtml(key)}</span>
            <span class="mv${vc}">${escapeHtml(value)}</span>
          </div>
        `;
      }
      list.innerHTML = html;
    }

    function renderYearlyChart(yearlyReturns) {
      const ctx = document.getElementById('yrChart').getContext('2d');
      const labels = yearlyReturns.map(d => d.year);
      const values = yearlyReturns.map(d => d.value);
      const colors = values.map(v => v >= 0 ? 'rgba(5,150,105,.82)' : 'rgba(220,38,38,.82)');
      
      yrChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Return (%)',
            data: values,
            backgroundColor: colors,
            borderRadius: 6,
            borderSkipped: false,
            barThickness: 30
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#0D1117',
              titleColor: '#E6EDF3',
              bodyColor: '#8B949E',
              padding: 10,
              cornerRadius: 8,
              callbacks: {
                label: function(c) { return c.parsed.y.toFixed(2) + '%'; }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: false,
              grid: { color: 'rgba(100,116,139,.08)' },
              ticks: {
                color: '#94A3B8',
                font: { size: 11, family: "'JetBrains Mono'" },
                callback: function(v) { return v + '%'; }
              }
            },
            x: {
              grid: { display: false },
              ticks: {
                color: '#94A3B8',
                font: { size: 11, family: "'JetBrains Mono'" }
              }
            }
          }
        }
      });
    }

    function renderHeatmap(monthlyReturns) {
      const MH = ['J','F','M','A','M','J','J','A','S','O','N','D'];
      const cont = document.getElementById('hmCont');
      if (!cont || !monthlyReturns.length) return;
      
      const yd = {};
      monthlyReturns.forEach(d => {
        if (!yd[d.year]) yd[d.year] = new Array(12).fill(null);
        yd[d.year][d.monthIndex] = d.value;
      });
      
      const years = Object.keys(yd).sort();
      let h = '<div class="hmg"><div class="hmc0"></div>';
      MH.forEach(m => { h += '<div class="hmmh">' + m + '</div>'; });
      
      years.forEach(yr => {
        h += '<div class="hmyr">' + yr + '</div>';
        for (let j = 0; j < 12; j++) {
          const v = yd[yr][j];
          if (v === null || v === undefined) {
            h += '<div class="hmcell nil"></div>';
          } else {
            const cl = hmC(v);
            const cs = v >= 0 ? 'pos' : 'neg';
            const dv = v >= 0 ? '+' + v.toFixed(0) : v.toFixed(0);
            h += '<div class="hmcell ' + cs + '" style="background:' + cl + '" title="' + yr + ' M' + (j+1) + ': ' + v.toFixed(2) + '%">' + dv + '</div>';
          }
        }
      });
      
      cont.innerHTML = h + '</div>';
    }

    function hmC(v) {
      if (v < -3) return '#DC2626';
      if (v < -1) return '#F87171';
      if (v < 0) return '#FCA5A5';
      if (v === 0) return '#E2E8F0';
      if (v < 1) return '#86EFAC';
      if (v < 3) return '#22C55E';
      return '#15803D';
    }

    function escapeHtml(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // Download functions
    function downloadJSON() {
      const s = strategyData;
      const data = {
        strategyName: s.assets.join('-') + '-' + s.timeframe,
        plan: s.plan,
        timeframe: s.timeframe,
        assets: s.assets,
        indicators: s.indicators,
        strategyLogic: s.strategyLogic,
        metrics: s.metrics,
        yearlyReturns: s.yearlyReturns,
        monthlyReturns: s.monthlyReturns,
        createdAt: s.createdAt,
        completedAt: s.updatedAt
      };
      
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'strategy_' + s._id + '.json';
      a.click();
      URL.revokeObjectURL(url);
    }

    function downloadCode() {
      if (!strategyData.generatedCode) {
        alert('Code not available');
        return;
      }
      const blob = new Blob([strategyData.generatedCode], { type: 'text/x-python' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'strategy_' + strategyData._id + '.py';
      a.click();
      URL.revokeObjectURL(url);
    }

    function downloadChart() {
      const img = document.getElementById('eqImg');
      if (!img.src) {
        alert('Chart not available');
        return;
      }
      const a = document.createElement('a');
      a.download = 'equity_curve_' + strategyData._id + '.png';
      a.href = img.src + '&t=' + Date.now();
      a.click();
    }

    function downloadAll() {
      downloadJSON();
      setTimeout(() => downloadCode(), 500);
      setTimeout(() => downloadChart(), 1000);
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', loadStrategy);
  </script>
</body>
</html>